                  "fontSize": 10,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "lpm4b",
                  "fill": "#4ECDC4",
                  "content": "  line.RenderTransform = new RotateTransform(i*6);",
