                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "pvcJL",
                  "fill": "#22D3EE",
                  "content": "  colorAnim.BeginTime = TimeSpan.FromMs(i*40);",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 10,
