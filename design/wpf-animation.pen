                  "fontWeight": "700",
                  "letterSpacing": 1
                },
                {
                  "type": "text",
                  "id": "AyNCd",
                  "fill": "#D8B4FE",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "/* Glitch jitter */\n@keyframes glitch {\n  0%,80% { transform: translate(0); opacity:1 }\n  5%  { transform: translate(-8px,3px); opacity:.3 }\n  10% { transform: translate(12px,-5px); opacity:1 }\n}\n/* Neon glow pulse */\n@keyframes neonPulse {\n  0%,100% { filter: drop-shadow(0 0 15px #22D3EE) }\n  50%     { filter: drop-shadow(0 0 40px #E040FB) }\n}\n/* RGB split */\n.rgb-r { color:#f008; transform:translate(-3px) }\n.rgb-b { color:#22D3EEaa; transform:translate(3px) }\n/* Scanline sweep */\n@keyframes scan {\n  from { transform: translateY(-20px) }\n  to   { transform: translateY(400px) }\n}",
                  "lineHeight": 1.4,
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 9,
                  "fontWeight": "normal"
                }
              ]
            }
          ]
        }
      ]
    },
