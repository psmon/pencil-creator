                  "fontSize": 10,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "XeogL",
                  "fill": "#22D3EE",
                  "content": "  trimAnim.BeginTime = TimeSpan.FromMs(i*40);",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 10,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "MKbS2",
                  "fill": "#64748B",
