          "children": [
            {
              "type": "frame",
              "id": "yuPUr",
              "name": "wpf-impl",
              "width": "fill_container",
              "fill": "#0F172A",
              "cornerRadius": 8,
              "layout": "vertical",
              "gap": 8,
              "padding": 16,
              "children": [
                {
                  "type": "text",
                  "id": "wEFOC",
                  "fill": "#22D3EE",
                  "content": "WPF IMPLEMENTATION",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 10,
                  "fontWeight": "700",
                  "letterSpacing": 1
                },
                {
                  "type": "text",
                  "id": "sOcA8",
                  "fill": "#7DD3FC",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "<Storyboard RepeatBehavior=\"Forever\">\n  <!-- Phase 1: Glitch burst -->\n  <DoubleAnimationUsingKeyFrames TargetProperty=\"X\">\n    <DiscreteDoubleKeyFrame KeyTime=\"0:0:0.05\" Value=\"-8\"/>\n    <DiscreteDoubleKeyFrame KeyTime=\"0:0:0.10\" Value=\"12\"/>\n  </DoubleAnimationUsingKeyFrames>\n  <!-- Phase 2: Neon pulse -->\n  <DoubleAnimation TargetProperty=\"BlurRadius\"\n    From=\"15\" To=\"40\" Duration=\"0:0:1.5\"\n    AutoReverse=\"True\">\n    <SineEase EasingMode=\"EaseInOut\"/>\n  </DoubleAnimation>\n  <!-- Phase 3: Color cycle -->\n  <ColorAnimation TargetProperty=\"Color\"\n    From=\"#22D3EE\" To=\"#E040FB\"\n    Duration=\"0:0:3\" AutoReverse=\"True\"/>\n</Storyboard>",
                  "lineHeight": 1.4,
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 9,
                  "fontWeight": "normal"
                }
              ]
            },
            {
              "type": "frame",
              "id": "INtyc",
              "name": "css-impl",
              "width": "fill_container",
              "fill": "#0F172A",
