<Window x:Class="WpfAnimations.RotatingLoadingSpinner"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Loading Spinners" Height="300" Width="600"
        Background="#1E1E2E">

    <Window.Resources>
        <!-- Reusable Spinner Style (IsEnabled 기반) -->
        <Style x:Key="SpinnerStyle" TargetType="Ellipse">
            <Setter Property="Width" Value="60" />
            <Setter Property="Height" Value="60" />
            <Setter Property="StrokeThickness" Value="4" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <RotateTransform />
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <StackPanel Orientation="Horizontal"
                HorizontalAlignment="Center" VerticalAlignment="Center">

        <!-- Spinner 1: DodgerBlue Dashed Circle -->
        <StackPanel Margin="30,0">
            <Canvas Width="80" Height="80">
                <!-- Background ring -->
                <Ellipse Width="60" Height="60"
                         Canvas.Left="10" Canvas.Top="10"
                         Stroke="#333" StrokeThickness="4" />
                <!-- Animated arc -->
                <Ellipse x:Name="spinner1"
                         Width="60" Height="60"
                         Canvas.Left="10" Canvas.Top="10"
                         Stroke="DodgerBlue" StrokeThickness="4"
                         StrokeDashArray="3 2" StrokeDashCap="Round"
                         RenderTransformOrigin="0.5,0.5">
                    <Ellipse.RenderTransform>
                        <RotateTransform x:Name="rotate1" />
                    </Ellipse.RenderTransform>
                    <Ellipse.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation
                                        Storyboard.TargetName="rotate1"
                                        Storyboard.TargetProperty="Angle"
                                        From="0" To="360"
                                        Duration="0:0:1" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Ellipse.Triggers>
                </Ellipse>
            </Canvas>
            <TextBlock Text="Dashed" Foreground="#666"
                       HorizontalAlignment="Center" FontSize="12" />
        </StackPanel>

        <!-- Spinner 2: Gradient Arc -->
        <StackPanel Margin="30,0">
            <Canvas Width="80" Height="80">
                <Ellipse Width="60" Height="60"
                         Canvas.Left="10" Canvas.Top="10"
                         Stroke="#333" StrokeThickness="5" />
                <Ellipse x:Name="spinner2"
                         Width="60" Height="60"
                         Canvas.Left="10" Canvas.Top="10"
                         Stroke="#8B5CF6" StrokeThickness="5"
                         StrokeDashArray="2.5 5" StrokeDashCap="Round"
                         RenderTransformOrigin="0.5,0.5">
                    <Ellipse.RenderTransform>
                        <RotateTransform x:Name="rotate2" />
                    </Ellipse.RenderTransform>
                    <Ellipse.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation
                                        Storyboard.TargetName="rotate2"
                                        Storyboard.TargetProperty="Angle"
                                        From="0" To="360"
                                        Duration="0:0:0.8" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Ellipse.Triggers>
                </Ellipse>
            </Canvas>
            <TextBlock Text="Arc" Foreground="#666"
                       HorizontalAlignment="Center" FontSize="12" />
        </StackPanel>

        <!-- Spinner 3: Bouncing Dots -->
        <StackPanel Margin="30,0">
            <Canvas Width="80" Height="80">
                <Ellipse x:Name="dot1" Width="14" Height="14"
                         Canvas.Left="10" Canvas.Top="33" Fill="DodgerBlue">
                    <Ellipse.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation
                                        Storyboard.TargetName="dot1"
                                        Storyboard.TargetProperty="Opacity"
                                        From="0.3" To="1" Duration="0:0:0.6"
                                        AutoReverse="True" BeginTime="0:0:0" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Ellipse.Triggers>
                </Ellipse>
                <Ellipse x:Name="dot2" Width="14" Height="14"
                         Canvas.Left="33" Canvas.Top="33" Fill="DodgerBlue">
                    <Ellipse.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation
                                        Storyboard.TargetName="dot2"
                                        Storyboard.TargetProperty="Opacity"
                                        From="0.3" To="1" Duration="0:0:0.6"
                                        AutoReverse="True" BeginTime="0:0:0.2" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Ellipse.Triggers>
                </Ellipse>
                <Ellipse x:Name="dot3" Width="14" Height="14"
                         Canvas.Left="56" Canvas.Top="33" Fill="DodgerBlue">
                    <Ellipse.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation
                                        Storyboard.TargetName="dot3"
                                        Storyboard.TargetProperty="Opacity"
                                        From="0.3" To="1" Duration="0:0:0.6"
                                        AutoReverse="True" BeginTime="0:0:0.4" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Ellipse.Triggers>
                </Ellipse>
            </Canvas>
            <TextBlock Text="Dots" Foreground="#666"
                       HorizontalAlignment="Center" FontSize="12" />
        </StackPanel>
    </StackPanel>
</Window>
