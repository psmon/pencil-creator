<Window x:Class="WpfAnimations.ColorAnimatedControl"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Color-Animated Content Control" Height="400" Width="500"
        Background="#1E1E2E">

    <Window.Resources>
        <!-- Color-Animated ControlTemplate -->
        <ControlTemplate x:Key="ColorAnimatedTemplate" TargetType="{x:Type ContentControl}">
            <Border Margin="{TemplateBinding Padding}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    Background="{TemplateBinding Background}"
                    CornerRadius="8">

                <!-- Inner Border: reacts to MouseEnter -->
                <Border x:Name="innerBorder" Padding="16" CornerRadius="6">
                    <Border.Background>
                        <SolidColorBrush x:Name="innerBorderBrush" Color="White" />
                    </Border.Background>

                    <!-- Content Panel: reacts to IsMouseOver -->
                    <Grid x:Name="contentPanel">
                        <Grid.Background>
                            <SolidColorBrush x:Name="contentPanelBrush" Color="White" />
                        </Grid.Background>
                        <ContentPresenter
                            Margin="12"
                            Content="{TemplateBinding Content}"
                            TextBlock.Foreground="{TemplateBinding Foreground}" />
                    </Grid>
                </Border>
            </Border>

            <ControlTemplate.Triggers>
                <!-- EventTrigger: MouseEnter → White to Light Blue (3s, auto-reverse) -->
                <EventTrigger RoutedEvent="Border.MouseEnter" SourceName="innerBorder">
                    <BeginStoryboard>
                        <Storyboard>
                            <ColorAnimation
                                Storyboard.TargetName="innerBorderBrush"
                                Storyboard.TargetProperty="Color"
                                From="White" To="#CCCCFF"
                                Duration="0:0:3"
                                AutoReverse="True" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>

                <!-- Property Trigger: IsMouseOver → Purple (1s) -->
                <Trigger Property="IsMouseOver" Value="True" SourceName="contentPanel">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <ColorAnimation
                                    Storyboard.TargetName="contentPanelBrush"
                                    Storyboard.TargetProperty="Color"
                                    To="Purple"
                                    Duration="0:0:1" />
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <ColorAnimation
                                    Storyboard.TargetName="contentPanelBrush"
                                    Storyboard.TargetProperty="Color"
                                    To="White"
                                    Duration="0:0:1" />
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>
    </Window.Resources>

    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="Hover over the card to see color animations"
                       Foreground="#94A3B8" FontSize="14"
                       HorizontalAlignment="Center" Margin="0,0,0,20" />

            <!-- Color-Animated Content Control -->
            <ContentControl
                Template="{StaticResource ColorAnimatedTemplate}"
                Width="300" Height="200"
                BorderBrush="#475569" BorderThickness="2"
                Padding="8" Foreground="#0A0F1C">
                <ContentControl.Background>
                    <SolidColorBrush Color="#2E333A" />
                </ContentControl.Background>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Interactive Card"
                               FontSize="18" FontWeight="Bold"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="MouseEnter → White to Blue (3s)"
                               FontSize="12" Margin="0,8,0,0"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="IsMouseOver → Purple (1s)"
                               FontSize="12" Margin="0,4,0,0"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="MouseLeave → Back to White (1s)"
                               FontSize="12" Margin="0,4,0,0"
                               HorizontalAlignment="Center" />
                </StackPanel>
            </ContentControl>
        </StackPanel>
    </Grid>
</Window>
