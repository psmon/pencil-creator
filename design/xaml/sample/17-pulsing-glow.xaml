<Window x:Class="WpfSample.PulsingGlow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pulsing Glow Buttons" Height="500" Width="700"
        Background="#1E1E2E" WindowStartupLocation="CenterScreen">

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <!-- Blue Glow: BlurRadius 10->30 -->
                    <DoubleAnimation Storyboard.TargetName="BlueGlow"
                                     Storyboard.TargetProperty="BlurRadius"
                                     From="10" To="30" Duration="0:0:1.2"
                                     AutoReverse="True" RepeatBehavior="Forever">
                        <DoubleAnimation.EasingFunction>
                            <SineEase EasingMode="EaseInOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <!-- Blue Glow: Opacity 0.4->0.9 -->
                    <DoubleAnimation Storyboard.TargetName="BlueGlow"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0.4" To="0.9" Duration="0:0:1.2"
                                     AutoReverse="True" RepeatBehavior="Forever">
                        <DoubleAnimation.EasingFunction>
                            <SineEase EasingMode="EaseInOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>

                    <!-- Purple Glow: BlurRadius 10->30 -->
                    <DoubleAnimation Storyboard.TargetName="PurpleGlow"
                                     Storyboard.TargetProperty="BlurRadius"
                                     From="10" To="30" Duration="0:0:1.2"
                                     AutoReverse="True" RepeatBehavior="Forever"
                                     BeginTime="0:0:0.3">
                        <DoubleAnimation.EasingFunction>
                            <SineEase EasingMode="EaseInOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="PurpleGlow"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0.4" To="0.9" Duration="0:0:1.2"
                                     AutoReverse="True" RepeatBehavior="Forever"
                                     BeginTime="0:0:0.3">
                        <DoubleAnimation.EasingFunction>
                            <SineEase EasingMode="EaseInOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>

                    <!-- Green Glow: BlurRadius 10->30 -->
                    <DoubleAnimation Storyboard.TargetName="GreenGlow"
                                     Storyboard.TargetProperty="BlurRadius"
                                     From="10" To="30" Duration="0:0:1.2"
                                     AutoReverse="True" RepeatBehavior="Forever"
                                     BeginTime="0:0:0.6">
                        <DoubleAnimation.EasingFunction>
                            <SineEase EasingMode="EaseInOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="GreenGlow"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0.4" To="0.9" Duration="0:0:1.2"
                                     AutoReverse="True" RepeatBehavior="Forever"
                                     BeginTime="0:0:0.6">
                        <DoubleAnimation.EasingFunction>
                            <SineEase EasingMode="EaseInOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>

                    <!-- Orange Glow: BlurRadius 10->30 -->
                    <DoubleAnimation Storyboard.TargetName="OrangeGlow"
                                     Storyboard.TargetProperty="BlurRadius"
                                     From="10" To="30" Duration="0:0:1.2"
                                     AutoReverse="True" RepeatBehavior="Forever"
                                     BeginTime="0:0:0.9">
                        <DoubleAnimation.EasingFunction>
                            <SineEase EasingMode="EaseInOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="OrangeGlow"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0.4" To="0.9" Duration="0:0:1.2"
                                     AutoReverse="True" RepeatBehavior="Forever"
                                     BeginTime="0:0:0.9">
                        <DoubleAnimation.EasingFunction>
                            <SineEase EasingMode="EaseInOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>

                    <!-- Pink Glow: BlurRadius 10->30 -->
                    <DoubleAnimation Storyboard.TargetName="PinkGlow"
                                     Storyboard.TargetProperty="BlurRadius"
                                     From="10" To="30" Duration="0:0:1.2"
                                     AutoReverse="True" RepeatBehavior="Forever"
                                     BeginTime="0:0:1.2">
                        <DoubleAnimation.EasingFunction>
                            <SineEase EasingMode="EaseInOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="PinkGlow"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0.4" To="0.9" Duration="0:0:1.2"
                                     AutoReverse="True" RepeatBehavior="Forever"
                                     BeginTime="0:0:1.2">
                        <DoubleAnimation.EasingFunction>
                            <SineEase EasingMode="EaseInOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Window.Resources>
        <!-- Glow Button Template -->
        <Style x:Key="GlowButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBorder" Background="{TemplateBinding Background}"
                                CornerRadius="10" Padding="28,14"
                                BorderThickness="1" BorderBrush="#3A3A4E">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="BorderBrush" Value="#5A5A7E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="Pulsing Glow Buttons" FontSize="28" FontWeight="Bold"
                       Foreground="#CDD6F4" HorizontalAlignment="Center" Margin="0,0,0,12"/>
            <TextBlock Text="Each button pulses with a different colored glow, staggered in timing"
                       FontSize="13" Foreground="#585B70" HorizontalAlignment="Center" Margin="0,0,0,40"/>

            <!-- Row 1 -->
            <WrapPanel HorizontalAlignment="Center" Margin="0,0,0,20">
                <!-- Blue Glow Button -->
                <Button Content="Primary Action" Background="#2A2A3E"
                        Style="{StaticResource GlowButtonStyle}" Margin="12">
                    <Button.Effect>
                        <DropShadowEffect x:Name="BlueGlow" ShadowDepth="0"
                                          Color="#2196F3" BlurRadius="10" Opacity="0.4"/>
                    </Button.Effect>
                </Button>

                <!-- Purple Glow Button -->
                <Button Content="Secondary" Background="#2A2A3E"
                        Style="{StaticResource GlowButtonStyle}" Margin="12">
                    <Button.Effect>
                        <DropShadowEffect x:Name="PurpleGlow" ShadowDepth="0"
                                          Color="#CE93D8" BlurRadius="10" Opacity="0.4"/>
                    </Button.Effect>
                </Button>

                <!-- Green Glow Button -->
                <Button Content="Success" Background="#2A2A3E"
                        Style="{StaticResource GlowButtonStyle}" Margin="12">
                    <Button.Effect>
                        <DropShadowEffect x:Name="GreenGlow" ShadowDepth="0"
                                          Color="#4CAF50" BlurRadius="10" Opacity="0.4"/>
                    </Button.Effect>
                </Button>
            </WrapPanel>

            <!-- Row 2 -->
            <WrapPanel HorizontalAlignment="Center">
                <!-- Orange Glow Button -->
                <Button Content="Warning" Background="#2A2A3E"
                        Style="{StaticResource GlowButtonStyle}" Margin="12">
                    <Button.Effect>
                        <DropShadowEffect x:Name="OrangeGlow" ShadowDepth="0"
                                          Color="#FF9800" BlurRadius="10" Opacity="0.4"/>
                    </Button.Effect>
                </Button>

                <!-- Pink Glow Button -->
                <Button Content="Danger" Background="#2A2A3E"
                        Style="{StaticResource GlowButtonStyle}" Margin="12">
                    <Button.Effect>
                        <DropShadowEffect x:Name="PinkGlow" ShadowDepth="0"
                                          Color="#F06292" BlurRadius="10" Opacity="0.4"/>
                    </Button.Effect>
                </Button>
            </WrapPanel>
        </StackPanel>
    </Grid>
</Window>
