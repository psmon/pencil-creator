<Window x:Class="WpfSamples.AnimatedProgressBar"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Animated ProgressBar" Height="500" Width="550"
        Background="#1E1E2E" WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- Indeterminate Progress Bar: sliding blue bar, repeats forever -->
        <Storyboard x:Key="IndeterminateAnimation" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="IndeterminateBar"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                             From="-200" To="500" Duration="0:0:1.5">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Value-based Progress Bar: 0% to 100% over 5 seconds -->
        <Storyboard x:Key="ValueProgressAnimation">
            <DoubleAnimation Storyboard.TargetName="ValueProgressFill"
                             Storyboard.TargetProperty="Width"
                             From="0" To="400" Duration="0:0:5">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <!-- Percentage text counter -->
            <DoubleAnimation Storyboard.TargetName="PercentRotation"
                             Storyboard.TargetProperty="Angle"
                             From="0" To="360" Duration="0:0:5"/>
        </Storyboard>

        <!-- Glow pulse for indeterminate -->
        <Storyboard x:Key="GlowPulse" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="IndeterminateGlow"
                             Storyboard.TargetProperty="Opacity"
                             From="0.3" To="0.8" Duration="0:0:0.8"/>
        </Storyboard>

        <!-- Button Style -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Bg"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0.8" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Bg"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="1" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Window.Triggers>
        <!-- Auto-start indeterminate animation on load -->
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard Storyboard="{StaticResource IndeterminateAnimation}"/>
            <BeginStoryboard Storyboard="{StaticResource GlowPulse}"/>
        </EventTrigger>
    </Window.Triggers>

    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="440">
            <!-- Title -->
            <TextBlock Text="Animated Progress Bars"
                       Foreground="#CDD6F4" FontSize="24" FontWeight="SemiBold"
                       HorizontalAlignment="Center" Margin="0,0,0,40"/>

            <!-- === Variant 1: Indeterminate === -->
            <TextBlock Text="Indeterminate (RepeatBehavior=Forever)"
                       Foreground="#888" FontSize="12" Margin="0,0,0,8"/>

            <!-- Track -->
            <Border Background="#2A2A3E" CornerRadius="6" Height="12"
                    ClipToBounds="True">
                <Grid>
                    <!-- Sliding Blue Bar -->
                    <Border x:Name="IndeterminateBar"
                            Background="#2196F3"
                            Width="120" Height="12"
                            CornerRadius="6"
                            HorizontalAlignment="Left">
                        <Border.RenderTransform>
                            <TranslateTransform X="-200"/>
                        </Border.RenderTransform>
                    </Border>
                    <!-- Glow effect overlay -->
                    <Border x:Name="IndeterminateGlow"
                            Background="#2196F3"
                            Width="60" Height="12"
                            CornerRadius="6"
                            HorizontalAlignment="Left"
                            Opacity="0.3">
                        <Border.Effect>
                            <BlurEffect Radius="10"/>
                        </Border.Effect>
                        <Border.RenderTransform>
                            <TranslateTransform X="-200"/>
                        </Border.RenderTransform>
                    </Border>
                </Grid>
            </Border>

            <TextBlock Text="Loading..." Foreground="#6C7086" FontSize="11"
                       Margin="0,6,0,0"/>

            <!-- Spacer -->
            <Border Height="1" Background="#333" Margin="0,24"/>

            <!-- === Variant 2: Value-Based Progress === -->
            <TextBlock Text="Value-Based (0 to 100% over 5 seconds, QuadraticEase)"
                       Foreground="#888" FontSize="12" Margin="0,0,0,8"/>

            <!-- Track -->
            <Border Background="#2A2A3E" CornerRadius="6" Height="12"
                    ClipToBounds="True" Width="400" HorizontalAlignment="Left">
                <!-- Fill -->
                <Border x:Name="ValueProgressFill"
                        Background="#4CAF50"
                        Width="0" Height="12"
                        CornerRadius="6"
                        HorizontalAlignment="Left"/>
            </Border>

            <!-- Hidden rotation target for percentage counter -->
            <Border Opacity="0" Width="0" Height="0">
                <Border.RenderTransform>
                    <RotateTransform x:Name="PercentRotation" Angle="0"/>
                </Border.RenderTransform>
            </Border>

            <TextBlock Text="Click 'Start' to begin" Foreground="#6C7086" FontSize="11"
                       Margin="0,6,0,0" x:Name="ValueHint"/>

            <!-- Start button for value-based progress -->
            <Button Content="Start Progress" Background="#4CAF50"
                    Style="{StaticResource ActionButtonStyle}"
                    HorizontalAlignment="Left" Margin="0,12,0,0">
                <Button.Triggers>
                    <EventTrigger RoutedEvent="Button.Click">
                        <BeginStoryboard Storyboard="{StaticResource ValueProgressAnimation}"/>
                    </EventTrigger>
                </Button.Triggers>
            </Button>

            <!-- Spacer -->
            <Border Height="1" Background="#333" Margin="0,24"/>

            <!-- === Variant 3: Thin Accent Bar === -->
            <TextBlock Text="Thin Accent Bar (Indeterminate)"
                       Foreground="#888" FontSize="12" Margin="0,0,0,8"/>

            <Border Background="#2A2A3E" CornerRadius="2" Height="4"
                    ClipToBounds="True">
                <Border Background="#FF9800" Width="80" Height="4"
                        CornerRadius="2" HorizontalAlignment="Left">
                    <Border.RenderTransform>
                        <TranslateTransform x:Name="ThinBarTranslate" X="-100"/>
                    </Border.RenderTransform>
                    <Border.Triggers>
                        <EventTrigger RoutedEvent="Border.Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                     From="-100" To="460" Duration="0:0:1.2">
                                        <DoubleAnimation.EasingFunction>
                                            <SineEase EasingMode="EaseInOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Border.Triggers>
                </Border>
            </Border>

            <!-- Hint -->
            <TextBlock Text="Indeterminate bars start automatically on load"
                       Foreground="#6C7086" FontSize="12"
                       HorizontalAlignment="Center" Margin="0,30,0,0"/>
        </StackPanel>
    </Grid>
</Window>
