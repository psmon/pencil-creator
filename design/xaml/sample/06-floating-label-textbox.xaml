<Window x:Class="WpfSamples.FloatingLabelTextBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Floating Label TextBox" Height="400" Width="500"
        Background="#1E1E2E" WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- Floating Label TextBox Style -->
        <Style x:Key="FloatingLabelTextBoxStyle" TargetType="TextBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="Padding" Value="4,8,4,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid>
                            <!-- Floating Label -->
                            <TextBlock x:Name="FloatingLabel"
                                       Text="{TemplateBinding Tag}"
                                       Foreground="Gray"
                                       FontSize="16"
                                       VerticalAlignment="Center"
                                       Margin="4,0,0,0"
                                       IsHitTestVisible="False"
                                       RenderTransformOrigin="0,0.5">
                                <TextBlock.RenderTransform>
                                    <TransformGroup>
                                        <TranslateTransform x:Name="LabelTranslate" Y="0"/>
                                        <ScaleTransform x:Name="LabelScale" ScaleX="1" ScaleY="1"/>
                                    </TransformGroup>
                                </TextBlock.RenderTransform>
                            </TextBlock>

                            <!-- Bottom Border -->
                            <Border x:Name="BottomBorder"
                                    BorderBrush="#555"
                                    BorderThickness="0,0,0,2"
                                    VerticalAlignment="Bottom"/>

                            <!-- Focus Highlight Border -->
                            <Border x:Name="FocusBorder"
                                    BorderBrush="#2196F3"
                                    BorderThickness="0,0,0,2"
                                    VerticalAlignment="Bottom"
                                    RenderTransformOrigin="0.5,0.5"
                                    Opacity="0">
                                <Border.RenderTransform>
                                    <ScaleTransform x:Name="FocusBorderScale" ScaleX="0"/>
                                </Border.RenderTransform>
                            </Border>

                            <!-- Actual Text Content -->
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="4,8,4,4"
                                          VerticalAlignment="Center"/>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <!-- Focus Animation -->
                            <Trigger Property="IsFocused" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <!-- Label moves up -->
                                            <DoubleAnimation Storyboard.TargetName="LabelTranslate"
                                                             Storyboard.TargetProperty="Y"
                                                             To="-18" Duration="0:0:0.25"
                                                             EasingFunction="{StaticResource {x:Null}}">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <!-- Label scales down -->
                                            <DoubleAnimation Storyboard.TargetName="LabelScale"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             To="0.75" Duration="0:0:0.25">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="LabelScale"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             To="0.75" Duration="0:0:0.25">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <!-- Label color to blue -->
                                            <ColorAnimation Storyboard.TargetName="FloatingLabel"
                                                            Storyboard.TargetProperty="(TextBlock.Foreground).(SolidColorBrush.Color)"
                                                            To="#2196F3" Duration="0:0:0.25"/>
                                            <!-- Focus border appears -->
                                            <DoubleAnimation Storyboard.TargetName="FocusBorder"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="1" Duration="0:0:0.25"/>
                                            <DoubleAnimation Storyboard.TargetName="FocusBorderScale"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             To="1" Duration="0:0:0.3">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <!-- Label moves back (only if empty) -->
                                            <DoubleAnimation Storyboard.TargetName="LabelTranslate"
                                                             Storyboard.TargetProperty="Y"
                                                             To="0" Duration="0:0:0.2"/>
                                            <DoubleAnimation Storyboard.TargetName="LabelScale"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             To="1" Duration="0:0:0.2"/>
                                            <DoubleAnimation Storyboard.TargetName="LabelScale"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             To="1" Duration="0:0:0.2"/>
                                            <ColorAnimation Storyboard.TargetName="FloatingLabel"
                                                            Storyboard.TargetProperty="(TextBlock.Foreground).(SolidColorBrush.Color)"
                                                            To="Gray" Duration="0:0:0.2"/>
                                            <DoubleAnimation Storyboard.TargetName="FocusBorder"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0" Duration="0:0:0.2"/>
                                            <DoubleAnimation Storyboard.TargetName="FocusBorderScale"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             To="0" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="350">
            <!-- Title -->
            <TextBlock Text="Floating Label TextBox"
                       Foreground="#CDD6F4" FontSize="24" FontWeight="SemiBold"
                       HorizontalAlignment="Center" Margin="0,0,0,40"/>

            <!-- Email Field -->
            <TextBox Tag="Email Address"
                     Style="{StaticResource FloatingLabelTextBoxStyle}"
                     Margin="0,20,0,0" Height="40"/>

            <!-- Username Field -->
            <TextBox Tag="Username"
                     Style="{StaticResource FloatingLabelTextBoxStyle}"
                     Margin="0,30,0,0" Height="40"/>

            <!-- Password Field -->
            <TextBox Tag="Password"
                     Style="{StaticResource FloatingLabelTextBoxStyle}"
                     Margin="0,30,0,0" Height="40"/>

            <!-- Hint Text -->
            <TextBlock Text="Click on a field to see the floating label animation"
                       Foreground="#6C7086" FontSize="12"
                       HorizontalAlignment="Center" Margin="0,30,0,0"/>
        </StackPanel>
    </Grid>
</Window>
