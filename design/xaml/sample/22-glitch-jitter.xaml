<Window x:Class="CyberEffects.GlitchJitterDemo"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Glitch Jitter Effect" Height="400" Width="600"
        Background="#0A0F1C">

    <!-- Glitch Jitter: rapid TranslateTransform offset + Opacity flicker -->
    <Grid>
        <Border x:Name="GlitchTarget"
                Width="300" Height="80"
                Background="#1E293B"
                BorderBrush="#22D3EE" BorderThickness="1"
                CornerRadius="8"
                RenderTransformOrigin="0.5,0.5">
            <Border.RenderTransform>
                <TransformGroup>
                    <TranslateTransform x:Name="GlitchTranslate" X="0" Y="0"/>
                    <ScaleTransform x:Name="GlitchScale" ScaleX="1" ScaleY="1"/>
                </TransformGroup>
            </Border.RenderTransform>
            <TextBlock Text="SYSTEM ERROR"
                       FontFamily="JetBrains Mono" FontSize="24" FontWeight="Bold"
                       Foreground="#22D3EE"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <Border.Triggers>
                <EventTrigger RoutedEvent="Border.Loaded">
                    <BeginStoryboard>
                        <Storyboard RepeatBehavior="Forever">
                            <!-- Rapid X jitter -->
                            <DoubleAnimationUsingKeyFrames
                                Storyboard.TargetName="GlitchTranslate"
                                Storyboard.TargetProperty="X">
                                <DiscreteDoubleKeyFrame KeyTime="0:0:0.00" Value="0"/>
                                <DiscreteDoubleKeyFrame KeyTime="0:0:0.05" Value="-8"/>
                                <DiscreteDoubleKeyFrame KeyTime="0:0:0.10" Value="12"/>
                                <DiscreteDoubleKeyFrame KeyTime="0:0:0.15" Value="-4"/>
                                <DiscreteDoubleKeyFrame KeyTime="0:0:0.20" Value="0"/>
                                <DiscreteDoubleKeyFrame KeyTime="0:0:0.80" Value="0"/>
                                <DiscreteDoubleKeyFrame KeyTime="0:0:0.85" Value="6"/>
                                <DiscreteDoubleKeyFrame KeyTime="0:0:0.90" Value="-10"/>
                                <DiscreteDoubleKeyFrame KeyTime="0:0:0.95" Value="3"/>
                                <DiscreteDoubleKeyFrame KeyTime="0:0:1.00" Value="0"/>
                            </DoubleAnimationUsingKeyFrames>

                            <!-- Y jitter (smaller amplitude) -->
                            <DoubleAnimationUsingKeyFrames
                                Storyboard.TargetName="GlitchTranslate"
                                Storyboard.TargetProperty="Y">
                                <DiscreteDoubleKeyFrame KeyTime="0:0:0.00" Value="0"/>
                                <DiscreteDoubleKeyFrame KeyTime="0:0:0.05" Value="3"/>
                                <DiscreteDoubleKeyFrame KeyTime="0:0:0.10" Value="-5"/>
                                <DiscreteDoubleKeyFrame KeyTime="0:0:0.15" Value="2"/>
                                <DiscreteDoubleKeyFrame KeyTime="0:0:0.20" Value="0"/>
                                <DiscreteDoubleKeyFrame KeyTime="0:0:1.00" Value="0"/>
                            </DoubleAnimationUsingKeyFrames>

                            <!-- Opacity flicker -->
                            <DoubleAnimationUsingKeyFrames
                                Storyboard.TargetName="GlitchTarget"
                                Storyboard.TargetProperty="Opacity">
                                <DiscreteDoubleKeyFrame KeyTime="0:0:0.00" Value="1"/>
                                <DiscreteDoubleKeyFrame KeyTime="0:0:0.07" Value="0.3"/>
                                <DiscreteDoubleKeyFrame KeyTime="0:0:0.12" Value="1"/>
                                <DiscreteDoubleKeyFrame KeyTime="0:0:0.17" Value="0.6"/>
                                <DiscreteDoubleKeyFrame KeyTime="0:0:0.22" Value="1"/>
                                <DiscreteDoubleKeyFrame KeyTime="0:0:1.00" Value="1"/>
                            </DoubleAnimationUsingKeyFrames>

                            <!-- ScaleX distortion burst -->
                            <DoubleAnimationUsingKeyFrames
                                Storyboard.TargetName="GlitchScale"
                                Storyboard.TargetProperty="ScaleX">
                                <DiscreteDoubleKeyFrame KeyTime="0:0:0.00" Value="1"/>
                                <DiscreteDoubleKeyFrame KeyTime="0:0:0.08" Value="1.03"/>
                                <DiscreteDoubleKeyFrame KeyTime="0:0:0.12" Value="0.97"/>
                                <DiscreteDoubleKeyFrame KeyTime="0:0:0.20" Value="1"/>
                                <DiscreteDoubleKeyFrame KeyTime="0:0:1.00" Value="1"/>
                            </DoubleAnimationUsingKeyFrames>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Border.Triggers>
        </Border>
    </Grid>
</Window>
