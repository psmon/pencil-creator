<Window x:Class="SpaceAstral.GalaxySwirlMotion"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Galaxy Swirl Motion" Height="600" Width="800"
        Background="#030712" WindowStartupLocation="CenterScreen">
    <!--
    Galaxy spiral: RotateTransform on concentric orbit rings
    Inner rings rotate faster, outer rings slower
    Center glow: DropShadowEffect with breathing pulse
    Particles positioned on spiral arms
    -->
    <Grid>
        <!-- Center core glow -->
        <Ellipse Width="30" Height="30" Fill="#8B5CF6"
                 HorizontalAlignment="Center" VerticalAlignment="Center">
            <Ellipse.Effect>
                <DropShadowEffect x:Name="coreGlow" ShadowDepth="0"
                    BlurRadius="40" Color="#8B5CF6" Opacity="0.8"/>
            </Ellipse.Effect>
            <Ellipse.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetName="coreGlow"
                                Storyboard.TargetProperty="BlurRadius"
                                From="30" To="60" Duration="0:0:4"
                                AutoReverse="True" RepeatBehavior="Forever">
                                <DoubleAnimation.EasingFunction>
                                    <SineEase EasingMode="EaseInOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Ellipse.Triggers>
        </Ellipse>

        <!-- Orbit ring 1 (inner, fast: 6s) -->
        <Canvas Width="120" Height="120" HorizontalAlignment="Center" VerticalAlignment="Center"
                RenderTransformOrigin="0.5,0.5">
            <Canvas.RenderTransform>
                <RotateTransform x:Name="orbit1Rot"/>
            </Canvas.RenderTransform>
            <Canvas.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetName="orbit1Rot"
                                Storyboard.TargetProperty="Angle"
                                From="0" To="360" Duration="0:0:6" RepeatBehavior="Forever"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Canvas.Triggers>
            <Ellipse Width="4" Height="4" Fill="#8B5CF680" Canvas.Left="108" Canvas.Top="58"/>
            <Ellipse Width="3" Height="3" Fill="#A78BFA60" Canvas.Left="5" Canvas.Top="55"/>
        </Canvas>

        <!-- Orbit ring 2 (mid, medium: 12s) -->
        <Canvas Width="220" Height="220" HorizontalAlignment="Center" VerticalAlignment="Center"
                RenderTransformOrigin="0.5,0.5">
            <Canvas.RenderTransform>
                <RotateTransform x:Name="orbit2Rot"/>
            </Canvas.RenderTransform>
            <Canvas.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetName="orbit2Rot"
                                Storyboard.TargetProperty="Angle"
                                From="0" To="360" Duration="0:0:12" RepeatBehavior="Forever"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Canvas.Triggers>
            <Ellipse Width="3" Height="3" Fill="#EC489960" Canvas.Left="210" Canvas.Top="108"/>
            <Ellipse Width="2" Height="2" Fill="#8B5CF650" Canvas.Left="3" Canvas.Top="105"/>
            <Ellipse Width="3" Height="3" Fill="#A78BFA40" Canvas.Left="108" Canvas.Top="3"/>
        </Canvas>

        <!-- Orbit ring 3 (outer, slow: 20s) -->
        <Canvas Width="340" Height="340" HorizontalAlignment="Center" VerticalAlignment="Center"
                RenderTransformOrigin="0.5,0.5">
            <Canvas.RenderTransform>
                <RotateTransform x:Name="orbit3Rot"/>
            </Canvas.RenderTransform>
            <Canvas.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetName="orbit3Rot"
                                Storyboard.TargetProperty="Angle"
                                From="0" To="360" Duration="0:0:20" RepeatBehavior="Forever"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Canvas.Triggers>
            <Ellipse Width="2" Height="2" Fill="#3B82F640" Canvas.Left="330" Canvas.Top="168"/>
            <Ellipse Width="2" Height="2" Fill="#8B5CF630" Canvas.Left="168" Canvas.Top="2"/>
        </Canvas>

        <!-- Orbit guide rings (static, dim) -->
        <Ellipse Width="120" Height="120" Fill="Transparent"
                 Stroke="#8B5CF612" StrokeThickness="0.5"
                 HorizontalAlignment="Center" VerticalAlignment="Center"/>
        <Ellipse Width="220" Height="220" Fill="Transparent"
                 Stroke="#A78BFA0A" StrokeThickness="0.5"
                 HorizontalAlignment="Center" VerticalAlignment="Center"/>
        <Ellipse Width="340" Height="340" Fill="Transparent"
                 Stroke="#8B5CF608" StrokeThickness="0.5"
                 HorizontalAlignment="Center" VerticalAlignment="Center"/>
    </Grid>
</Window>
