<Window x:Class="WpfAnimations.SlidingExpandablePanel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sliding Expandable Panel" Height="400" Width="700"
        Background="#1E1E2E">

    <Window.Resources>
        <!-- Expand Storyboard -->
        <Storyboard x:Key="ExpandPanel"
                    Storyboard.TargetName="sidePanel"
                    Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)">
            <DoubleAnimation
                From="250" To="0"
                Duration="0:0:0.6"
                AccelerationRatio="0.4"
                DecelerationRatio="0.4" />
        </Storyboard>

        <!-- Collapse Storyboard -->
        <Storyboard x:Key="CollapsePanel"
                    Storyboard.TargetName="sidePanel"
                    Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)">
            <DoubleAnimation
                From="0" To="250"
                Duration="0:0:0.6"
                AccelerationRatio="0.4"
                DecelerationRatio="0.4" />
        </Storyboard>
    </Window.Resources>

    <Grid ClipToBounds="True">
        <!-- Main Content -->
        <StackPanel Margin="30">
            <TextBlock Text="Main Content Area"
                       Foreground="#94A3B8" FontSize="18" FontWeight="SemiBold" />
            <Rectangle Height="10" Fill="#2E333A" RadiusX="4" RadiusY="4"
                       Margin="0,20,200,0" />
            <Rectangle Height="10" Fill="#2E333A" RadiusX="4" RadiusY="4"
                       Margin="0,10,240,0" />
            <Rectangle Height="10" Fill="#2E333A" RadiusX="4" RadiusY="4"
                       Margin="0,10,220,0" />
        </StackPanel>

        <!-- Sliding Side Panel -->
        <StackPanel x:Name="sidePanel"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
            <StackPanel.RenderTransform>
                <TranslateTransform X="250" />
            </StackPanel.RenderTransform>

            <!-- Tab Button (toggle) -->
            <Border Width="24" Height="60"
                    Background="#22D3EE"
                    CornerRadius="6,0,0,6"
                    VerticalAlignment="Top" Margin="0,30,0,0"
                    Cursor="Hand"
                    MouseDown="TabButton_MouseDown">
                <TextBlock Text="◀" Foreground="#0A0F1C"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="12" FontWeight="Bold" />
            </Border>

            <!-- Properties Panel -->
            <Border x:Name="propertiesPanel"
                    Width="250" Background="#1E293B"
                    BorderBrush="#22D3EE" BorderThickness="2,0,0,0">
                <StackPanel Margin="20">
                    <TextBlock Text="Properties"
                               Foreground="White" FontSize="16"
                               FontWeight="SemiBold" Margin="0,0,0,20" />

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Width" Foreground="#64748B"
                                   FontFamily="Consolas" FontSize="13" />
                        <TextBlock Text="320px" Foreground="#22D3EE"
                                   Grid.Column="1" FontFamily="Consolas"
                                   FontSize="13" TextAlignment="Right" />
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Height" Foreground="#64748B"
                                   FontFamily="Consolas" FontSize="13" />
                        <TextBlock Text="240px" Foreground="#22D3EE"
                                   Grid.Column="1" FontFamily="Consolas"
                                   FontSize="13" TextAlignment="Right" />
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Opacity" Foreground="#64748B"
                                   FontFamily="Consolas" FontSize="13" />
                        <TextBlock Text="1.0" Foreground="#22D3EE"
                                   Grid.Column="1" FontFamily="Consolas"
                                   FontSize="13" TextAlignment="Right" />
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Rotation" Foreground="#64748B"
                                   FontFamily="Consolas" FontSize="13" />
                        <TextBlock Text="0°" Foreground="#22D3EE"
                                   Grid.Column="1" FontFamily="Consolas"
                                   FontSize="13" TextAlignment="Right" />
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Window>
