<Window x:Class="WpfAnimations.AnimatedSidebarMenu"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Animated Sidebar Menu" Height="450" Width="600"
        Background="#1E1E2E">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar Navigation Panel -->
        <StackPanel x:Name="nav_pnl" Width="65" Background="#2E333A"
                    Grid.Column="0">

            <!-- Hamburger Toggle Button -->
            <ToggleButton x:Name="menuToggle"
                Height="50" Width="65"
                Background="Transparent" BorderThickness="0"
                Foreground="White" Content="☰" FontSize="20">
                <ToggleButton.Triggers>
                    <!-- Expand: Checked -->
                    <EventTrigger RoutedEvent="ToggleButton.Checked">
                        <BeginStoryboard>
                            <Storyboard x:Name="ShowStackPanel">
                                <DoubleAnimation
                                    Storyboard.TargetName="nav_pnl"
                                    Storyboard.TargetProperty="Width"
                                    From="65" To="230"
                                    Duration="0:0:0.3">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut" />
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>

                    <!-- Collapse: Unchecked -->
                    <EventTrigger RoutedEvent="ToggleButton.Unchecked">
                        <BeginStoryboard>
                            <Storyboard x:Name="HideStackPanel">
                                <DoubleAnimation
                                    Storyboard.TargetName="nav_pnl"
                                    Storyboard.TargetProperty="Width"
                                    From="230" To="65"
                                    Duration="0:0:0.2">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseIn" />
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </ToggleButton.Triggers>
            </ToggleButton>

            <!-- Menu Items -->
            <ListView Background="Transparent" BorderThickness="0"
                      Foreground="White" FontFamily="Segoe UI" FontSize="14">
                <ListViewItem Height="40">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🏠" Width="24" Margin="12,0,0,0" />
                        <TextBlock Text="Home" Margin="25,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </ListViewItem>
                <ListViewItem Height="40">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="👥" Width="24" Margin="12,0,0,0" />
                        <TextBlock Text="Contacts" Margin="25,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </ListViewItem>
                <ListViewItem Height="40">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="✉️" Width="24" Margin="12,0,0,0" />
                        <TextBlock Text="Messages" Margin="25,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </ListViewItem>
                <ListViewItem Height="40">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🗺️" Width="24" Margin="12,0,0,0" />
                        <TextBlock Text="Maps" Margin="25,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </ListViewItem>
                <ListViewItem Height="40">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚙️" Width="24" Margin="12,0,0,0" />
                        <TextBlock Text="Settings" Margin="25,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </ListViewItem>
            </ListView>
        </StackPanel>

        <!-- Main Content Area -->
        <Grid Grid.Column="1" Background="#1E1E2E">
            <TextBlock Text="Main Content Area"
                       Foreground="#666" FontSize="20"
                       HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Grid>
    </Grid>
</Window>
