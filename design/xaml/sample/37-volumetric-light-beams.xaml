<Window x:Class="SpaceAstral.VolumetricLightBeams"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Volumetric Light Beams" Height="600" Width="800"
        Background="#030712" WindowStartupLocation="CenterScreen">
    <!--
    Fake volumetric light beams using Path + LinearGradientBrush + BlurEffect
    Light source at top, cone expands downward
    Opacity breathing (SineEase 3s AutoReverse Forever)
    Multiple scatter layers for depth
    -->
    <Grid>
        <!-- Primary beam (purple) -->
        <Path Stretch="Fill" Width="300" Height="500"
              HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,20,0,0">
            <Path.Data>
                <PathGeometry>
                    <PathFigure StartPoint="150,0">
                        <LineSegment Point="50,500"/>
                        <LineSegment Point="250,500"/>
                    </PathFigure>
                </PathGeometry>
            </Path.Data>
            <Path.Fill>
                <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                    <GradientStop Color="#8B5CF650" Offset="0"/>
                    <GradientStop Color="#8B5CF600" Offset="1"/>
                </LinearGradientBrush>
            </Path.Fill>
            <Path.Effect>
                <BlurEffect Radius="8"/>
            </Path.Effect>
            <Path.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                From="0.3" To="0.8" Duration="0:0:3"
                                AutoReverse="True" RepeatBehavior="Forever">
                                <DoubleAnimation.EasingFunction>
                                    <SineEase EasingMode="EaseInOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Path.Triggers>
        </Path>

        <!-- Secondary beam (blue, offset) -->
        <Path Stretch="Fill" Width="180" Height="450"
              HorizontalAlignment="Left" VerticalAlignment="Top" Margin="80,50,0,0"
              Opacity="0.4">
            <Path.Data>
                <PathGeometry>
                    <PathFigure StartPoint="90,0">
                        <LineSegment Point="20,450"/>
                        <LineSegment Point="160,450"/>
                    </PathFigure>
                </PathGeometry>
            </Path.Data>
            <Path.Fill>
                <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                    <GradientStop Color="#3B82F640" Offset="0"/>
                    <GradientStop Color="#3B82F600" Offset="1"/>
                </LinearGradientBrush>
            </Path.Fill>
            <Path.Effect>
                <BlurEffect Radius="10"/>
            </Path.Effect>
            <Path.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                From="0.2" To="0.6" Duration="0:0:4"
                                AutoReverse="True" RepeatBehavior="Forever"
                                BeginTime="0:0:1">
                                <DoubleAnimation.EasingFunction>
                                    <SineEase EasingMode="EaseInOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Path.Triggers>
        </Path>

        <!-- Light source glow points -->
        <Ellipse Width="12" Height="12" Fill="#8B5CF6"
                 HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,15,0,0">
            <Ellipse.Effect>
                <DropShadowEffect ShadowDepth="0" BlurRadius="20" Color="#8B5CF6" Opacity="0.8"/>
            </Ellipse.Effect>
        </Ellipse>
        <Ellipse Width="8" Height="8" Fill="#3B82F6"
                 HorizontalAlignment="Left" VerticalAlignment="Top" Margin="167,45,0,0">
            <Ellipse.Effect>
                <DropShadowEffect ShadowDepth="0" BlurRadius="15" Color="#3B82F6" Opacity="0.6"/>
            </Ellipse.Effect>
        </Ellipse>
    </Grid>
</Window>
