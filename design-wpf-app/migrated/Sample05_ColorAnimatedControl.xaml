<UserControl x:Class="design_wpf_app.Migrated.Sample05_ColorAnimatedControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="500"
             Background="#1E1E2E">

    <UserControl.Resources>
        <Storyboard x:Key="BorderColorToBlue">
            <ColorAnimation Storyboard.TargetName="innerBorderBrush"
                Storyboard.TargetProperty="Color"
                From="White" To="#CCCCFF" Duration="0:0:3"
                AutoReverse="True" />
        </Storyboard>

        <Storyboard x:Key="ContentColorToPurple">
            <ColorAnimation Storyboard.TargetName="contentPanelBrush"
                Storyboard.TargetProperty="Color"
                From="White" To="Purple" Duration="0:0:1" />
        </Storyboard>

        <Storyboard x:Key="ContentColorToWhite">
            <ColorAnimation Storyboard.TargetName="contentPanelBrush"
                Storyboard.TargetProperty="Color"
                From="Purple" To="White" Duration="0:0:1" />
        </Storyboard>

        <!-- ★ DemoSequence
             원본 의도: 2계층 색상 반응 카드 (외곽 보더 + 내부 콘텐츠)
             시나리오: 마우스 진입 → 외곽 보더 White→LightBlue(3s, 자동역재생)
                       + 내부 콘텐츠 영역 White→Purple(1s)
                       → 마우스 이탈 → Purple→White 복원(1s)
             핵심 기법: ColorAnimation으로 SolidColorBrush.Color 전환, 2계층 독립 반응
             다른 플랫폼:
               - 웹: CSS transition on background-color, 부모/자식 별도 hover 셀렉터
               - 모바일: 터치 하이라이트 + 영역별 색상 반응
        -->
        <Storyboard x:Key="DemoSequence">
            <!-- Phase 1: 외곽 보더 색상 변환 (0~3s, 자동역재생) -->
            <ColorAnimation Storyboard.TargetName="innerBorderBrush"
                Storyboard.TargetProperty="Color"
                From="White" To="#CCCCFF" Duration="0:0:3"
                AutoReverse="True"
                BeginTime="0:0:0" FillBehavior="HoldEnd" />
            <!-- Phase 2: 내부 콘텐츠 White→Purple (0.5~1.5s) -->
            <ColorAnimation Storyboard.TargetName="contentPanelBrush"
                Storyboard.TargetProperty="Color"
                From="White" To="Purple" Duration="0:0:1"
                BeginTime="0:0:0.5" FillBehavior="HoldEnd" />
            <!-- Phase 3: 내부 콘텐츠 Purple→White 복원 (4~5s) -->
            <ColorAnimation Storyboard.TargetName="contentPanelBrush"
                Storyboard.TargetProperty="Color"
                To="White" Duration="0:0:1"
                BeginTime="0:0:4" FillBehavior="HoldEnd" />
        </Storyboard>
    </UserControl.Resources>

    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="Hover over the card to see color animations"
                       Foreground="#94A3B8" FontSize="14"
                       HorizontalAlignment="Center" Margin="0,0,0,20" />

            <!-- Outer Border -->
            <Border Padding="8" BorderBrush="#475569" BorderThickness="2"
                    CornerRadius="8" Background="#2E333A"
                    Width="300" Height="200">

                <!-- Inner Border: color animated -->
                <Border x:Name="innerBorder" Padding="16" CornerRadius="6"
                        MouseEnter="InnerBorder_MouseEnter">
                    <Border.Background>
                        <SolidColorBrush x:Name="innerBorderBrush" Color="White" />
                    </Border.Background>

                    <!-- Content Panel -->
                    <Grid x:Name="contentPanel"
                          MouseEnter="ContentPanel_MouseEnter"
                          MouseLeave="ContentPanel_MouseLeave">
                        <Grid.Background>
                            <SolidColorBrush x:Name="contentPanelBrush" Color="White" />
                        </Grid.Background>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Interactive Card"
                                       FontSize="18" FontWeight="Bold"
                                       Foreground="#0A0F1C"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="MouseEnter → White to Blue (3s)"
                                       FontSize="12" Margin="0,8,0,0"
                                       Foreground="#0A0F1C"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="IsMouseOver → Purple (1s)"
                                       FontSize="12" Margin="0,4,0,0"
                                       Foreground="#0A0F1C"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
