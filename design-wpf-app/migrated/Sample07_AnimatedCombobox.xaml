<UserControl x:Class="design_wpf_app.Migrated.Sample07_AnimatedCombobox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="500"
             Background="#1E1E2E">

    <UserControl.Resources>
        <Storyboard x:Key="ArrowRotateOpen">
            <DoubleAnimation Storyboard.TargetName="arrowRotate"
                Storyboard.TargetProperty="Angle"
                From="0" To="180" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseInOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Storyboard x:Key="ArrowRotateClose">
            <DoubleAnimation Storyboard.TargetName="arrowRotate"
                Storyboard.TargetProperty="Angle"
                From="180" To="0" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseInOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Storyboard x:Key="DropdownOpen">
            <DoubleAnimation Storyboard.TargetName="dropdownScale"
                Storyboard.TargetProperty="ScaleY"
                From="0" To="1" Duration="0:0:0.25">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="dropdownBorder"
                Storyboard.TargetProperty="Opacity"
                From="0" To="1" Duration="0:0:0.25" />
        </Storyboard>

        <Storyboard x:Key="DropdownClose">
            <DoubleAnimation Storyboard.TargetName="dropdownScale"
                Storyboard.TargetProperty="ScaleY"
                From="1" To="0" Duration="0:0:0.2" />
            <DoubleAnimation Storyboard.TargetName="dropdownBorder"
                Storyboard.TargetProperty="Opacity"
                From="1" To="0" Duration="0:0:0.2" />
        </Storyboard>

        <Storyboard x:Key="BorderHighlight">
            <ColorAnimation Storyboard.TargetName="comboBoxBorderBrush"
                Storyboard.TargetProperty="Color"
                From="#475569" To="#3B82F6" Duration="0:0:0.3" />
        </Storyboard>

        <Storyboard x:Key="BorderNormal">
            <ColorAnimation Storyboard.TargetName="comboBoxBorderBrush"
                Storyboard.TargetProperty="Color"
                From="#3B82F6" To="#475569" Duration="0:0:0.3" />
        </Storyboard>

        <!-- ★ DemoSequence
             원본 의도: 애니메이션 콤보박스 — 드롭다운 열림/닫힘 시 화살표 회전 + 목록 스케일 전환
             시나리오: 클릭 → 보더 하이라이트 + 화살표 0→180 회전 + 드롭다운 ScaleY 0→1 페이드인
                       → 2초 유지 → 역방향으로 닫힘 (화살표 180→0, 드롭다운 ScaleY 1→0)
             핵심 기법: RotateTransform(화살표), ScaleTransform.ScaleY(드롭다운 펼침),
                        ColorAnimation(보더 강조), Opacity(페이드)
             다른 플랫폼:
               - 웹: CSS transform: rotate(180deg) + max-height/scaleY transition
               - 모바일: 네이티브 Picker 또는 BottomSheet + 화살표 회전 애니메이션
        -->
        <Storyboard x:Key="DemoSequence">
            <!-- Phase 1: Open (0~0.3s) — border highlight + arrow rotate + dropdown scale -->
            <ColorAnimation Storyboard.TargetName="comboBoxBorderBrush"
                Storyboard.TargetProperty="Color"
                From="#475569" To="#3B82F6" Duration="0:0:0.3"
                BeginTime="0:0:0" FillBehavior="HoldEnd" />
            <DoubleAnimation Storyboard.TargetName="arrowRotate"
                Storyboard.TargetProperty="Angle"
                From="0" To="180" Duration="0:0:0.3"
                BeginTime="0:0:0" FillBehavior="HoldEnd">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseInOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="dropdownScale"
                Storyboard.TargetProperty="ScaleY"
                From="0" To="1" Duration="0:0:0.25"
                BeginTime="0:0:0" FillBehavior="HoldEnd">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="dropdownBorder"
                Storyboard.TargetProperty="Opacity"
                From="0" To="1" Duration="0:0:0.25"
                BeginTime="0:0:0" FillBehavior="HoldEnd" />

            <!-- Phase 2: Close (2.3~2.6s) — reverse all -->
            <ColorAnimation Storyboard.TargetName="comboBoxBorderBrush"
                Storyboard.TargetProperty="Color"
                To="#475569" Duration="0:0:0.3"
                BeginTime="0:0:2.3" FillBehavior="HoldEnd" />
            <DoubleAnimation Storyboard.TargetName="arrowRotate"
                Storyboard.TargetProperty="Angle"
                To="0" Duration="0:0:0.3"
                BeginTime="0:0:2.3" FillBehavior="HoldEnd">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseInOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="dropdownScale"
                Storyboard.TargetProperty="ScaleY"
                To="0" Duration="0:0:0.2"
                BeginTime="0:0:2.3" FillBehavior="HoldEnd" />
            <DoubleAnimation Storyboard.TargetName="dropdownBorder"
                Storyboard.TargetProperty="Opacity"
                To="0" Duration="0:0:0.2"
                BeginTime="0:0:2.3" FillBehavior="HoldEnd" />
        </Storyboard>

        <Style x:Key="HitButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="280">
            <TextBlock Text="Animated Combobox"
                       Foreground="#94A3B8" FontSize="14"
                       HorizontalAlignment="Center" Margin="0,0,0,20" />

            <!-- ComboBox Header -->
            <Border x:Name="comboBoxHeader" Height="44" CornerRadius="6"
                    BorderThickness="2" Padding="12,0">
                <Border.BorderBrush>
                    <SolidColorBrush x:Name="comboBoxBorderBrush" Color="#475569" />
                </Border.BorderBrush>
                <Border.Background>
                    <SolidColorBrush Color="#2E333A" />
                </Border.Background>
                <Grid>
                    <TextBlock Text="Select an option..."
                               Foreground="#94A3B8" FontSize="14"
                               VerticalAlignment="Center" />
                    <!-- Arrow Chevron -->
                    <Path x:Name="arrowChevron"
                          Data="M 0,0 L 6,6 L 12,0"
                          Stroke="White" StrokeThickness="2"
                          HorizontalAlignment="Right" VerticalAlignment="Center"
                          RenderTransformOrigin="0.5,0.5"
                          Fill="Transparent">
                        <Path.RenderTransform>
                            <RotateTransform x:Name="arrowRotate" Angle="0" />
                        </Path.RenderTransform>
                    </Path>
                </Grid>
            </Border>

            <!-- Dropdown List (simulated) -->
            <Border x:Name="dropdownBorder" Opacity="0"
                    Background="#2E333A" BorderBrush="#475569"
                    BorderThickness="1" CornerRadius="0,0,6,6"
                    Margin="0,-1,0,0" Padding="4"
                    RenderTransformOrigin="0.5,0">
                <Border.RenderTransform>
                    <ScaleTransform x:Name="dropdownScale" ScaleY="0" ScaleX="1" />
                </Border.RenderTransform>
                <StackPanel>
                    <TextBlock Text="Option 1" Foreground="#E2E8F0" FontSize="14"
                               Margin="8,6" />
                    <TextBlock Text="Option 2" Foreground="#E2E8F0" FontSize="14"
                               Margin="8,6" />
                    <TextBlock Text="Option 3" Foreground="#E2E8F0" FontSize="14"
                               Margin="8,6" />
                </StackPanel>
            </Border>

            <!-- Hit area overlay for click trigger -->
            <Button x:Name="toggleButton"
                    Style="{StaticResource HitButtonStyle}"
                    Width="280" Height="44"
                    Margin="0,-120,0,0" VerticalAlignment="Top">
                <Button.Triggers>
                    <EventTrigger RoutedEvent="Button.Click">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="arrowRotate"
                                    Storyboard.TargetProperty="Angle"
                                    From="0" To="180" Duration="0:0:0.3">
                                    <DoubleAnimation.EasingFunction>
                                        <QuadraticEase EasingMode="EaseInOut" />
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <ColorAnimation Storyboard.TargetName="comboBoxBorderBrush"
                                    Storyboard.TargetProperty="Color"
                                    From="#475569" To="#3B82F6" Duration="0:0:0.3" />
                                <DoubleAnimation Storyboard.TargetName="dropdownScale"
                                    Storyboard.TargetProperty="ScaleY"
                                    From="0" To="1" Duration="0:0:0.25">
                                    <DoubleAnimation.EasingFunction>
                                        <QuadraticEase EasingMode="EaseOut" />
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetName="dropdownBorder"
                                    Storyboard.TargetProperty="Opacity"
                                    From="0" To="1" Duration="0:0:0.25" />
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Button.Triggers>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
