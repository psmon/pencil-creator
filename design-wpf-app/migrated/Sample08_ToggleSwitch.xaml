<UserControl x:Class="design_wpf_app.Migrated.Sample08_ToggleSwitch"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="400"
             Background="#1E1E2E">

    <UserControl.Resources>
        <Storyboard x:Key="ToggleOn">
            <DoubleAnimation Storyboard.TargetName="knobTranslate"
                Storyboard.TargetProperty="X"
                From="0" To="22" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <ColorAnimation Storyboard.TargetName="trackBrush"
                Storyboard.TargetProperty="Color"
                From="#6B7280" To="#22C55E" Duration="0:0:0.3" />
        </Storyboard>

        <Storyboard x:Key="ToggleOff">
            <DoubleAnimation Storyboard.TargetName="knobTranslate"
                Storyboard.TargetProperty="X"
                From="22" To="0" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <ColorAnimation Storyboard.TargetName="trackBrush"
                Storyboard.TargetProperty="Color"
                From="#22C55E" To="#6B7280" Duration="0:0:0.3" />
        </Storyboard>

        <Storyboard x:Key="KnobHoverEnlarge">
            <DoubleAnimation Storyboard.TargetName="knobScale"
                Storyboard.TargetProperty="ScaleX"
                To="1.111" Duration="0:0:0.15" />
            <DoubleAnimation Storyboard.TargetName="knobScale"
                Storyboard.TargetProperty="ScaleY"
                To="1.111" Duration="0:0:0.15" />
        </Storyboard>

        <Storyboard x:Key="KnobHoverNormal">
            <DoubleAnimation Storyboard.TargetName="knobScale"
                Storyboard.TargetProperty="ScaleX"
                To="1.0" Duration="0:0:0.15" />
            <DoubleAnimation Storyboard.TargetName="knobScale"
                Storyboard.TargetProperty="ScaleY"
                To="1.0" Duration="0:0:0.15" />
        </Storyboard>

        <!-- ★ DemoSequence
             원본 의도: iOS 스타일 토글 스위치 — 노브 슬라이드 + 트랙 색상 전환
             시나리오: 클릭 → 노브가 왼→오 슬라이드(TranslateTransform.X 0→22)
                       + 트랙 배경 Gray→Green 색상 전환
                       → 2초 유지 → 역방향 (노브 오→왼, Green→Gray)
             핵심 기법: TranslateTransform.X(노브 이동), ColorAnimation(트랙 배경),
                        ScaleTransform(호버 시 노브 확대 18→20)
             다른 플랫폼:
               - 웹: CSS transform: translateX() + background-color transition
               - 모바일: 네이티브 Switch/Toggle 위젯, 커스텀 시 thumb 위치 애니메이션
        -->
        <Storyboard x:Key="DemoSequence">
            <!-- Phase 1: Toggle ON (0~0.3s) — knob slides right + track turns green -->
            <DoubleAnimation Storyboard.TargetName="knobTranslate"
                Storyboard.TargetProperty="X"
                From="0" To="22" Duration="0:0:0.3"
                BeginTime="0:0:0" FillBehavior="HoldEnd">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <ColorAnimation Storyboard.TargetName="trackBrush"
                Storyboard.TargetProperty="Color"
                From="#6B7280" To="#22C55E" Duration="0:0:0.3"
                BeginTime="0:0:0" FillBehavior="HoldEnd" />

            <!-- Phase 2: Toggle OFF (2.3~2.6s) — reverse -->
            <DoubleAnimation Storyboard.TargetName="knobTranslate"
                Storyboard.TargetProperty="X"
                To="0" Duration="0:0:0.3"
                BeginTime="0:0:2.3" FillBehavior="HoldEnd">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <ColorAnimation Storyboard.TargetName="trackBrush"
                Storyboard.TargetProperty="Color"
                To="#6B7280" Duration="0:0:0.3"
                BeginTime="0:0:2.3" FillBehavior="HoldEnd" />
        </Storyboard>

        <Style x:Key="HitButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                    Orientation="Horizontal">

            <TextBlock Text="Toggle Switch" Foreground="#94A3B8" FontSize="14"
                       VerticalAlignment="Center" Margin="0,0,20,0" />

            <!-- Toggle Track + Knob extracted at root level -->
            <Grid Width="48" Height="26">
                <!-- Track Background -->
                <Border x:Name="trackBorder" CornerRadius="13"
                        Width="48" Height="26">
                    <Border.Background>
                        <SolidColorBrush x:Name="trackBrush" Color="#6B7280" />
                    </Border.Background>
                </Border>

                <!-- Knob (circle) -->
                <Border x:Name="knob"
                        Width="18" Height="18"
                        CornerRadius="9"
                        Background="White"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Margin="4,0,0,0"
                        RenderTransformOrigin="0.5,0.5">
                    <Border.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform x:Name="knobScale" ScaleX="1" ScaleY="1" />
                            <TranslateTransform x:Name="knobTranslate" X="0" />
                        </TransformGroup>
                    </Border.RenderTransform>
                </Border>

                <!-- Hit area -->
                <Button x:Name="hitArea"
                        Style="{StaticResource HitButtonStyle}"
                        Width="48" Height="26">
                    <Button.Triggers>
                        <EventTrigger RoutedEvent="Button.Click">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="knobTranslate"
                                        Storyboard.TargetProperty="X"
                                        From="0" To="22" Duration="0:0:0.3">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut" />
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <ColorAnimation Storyboard.TargetName="trackBrush"
                                        Storyboard.TargetProperty="Color"
                                        From="#6B7280" To="#22C55E" Duration="0:0:0.3" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="knobScale"
                                        Storyboard.TargetProperty="ScaleX"
                                        To="1.111" Duration="0:0:0.15" />
                                    <DoubleAnimation Storyboard.TargetName="knobScale"
                                        Storyboard.TargetProperty="ScaleY"
                                        To="1.111" Duration="0:0:0.15" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="knobScale"
                                        Storyboard.TargetProperty="ScaleX"
                                        To="1.0" Duration="0:0:0.15" />
                                    <DoubleAnimation Storyboard.TargetName="knobScale"
                                        Storyboard.TargetProperty="ScaleY"
                                        To="1.0" Duration="0:0:0.15" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Button.Triggers>
                </Button>
            </Grid>
        </StackPanel>
    </Grid>
</UserControl>
