<UserControl x:Class="design_wpf_app.Migrated.Sample15_AnimatedGradientBg"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="700">

    <UserControl.Background>
        <LinearGradientBrush x:Name="GradBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop x:Name="Stop1" Color="#667eea" Offset="0.0"/>
            <GradientStop x:Name="Stop2" Color="#764ba2" Offset="0.5"/>
            <GradientStop x:Name="Stop3" Color="#f093fb" Offset="1.0"/>
        </LinearGradientBrush>
    </UserControl.Background>

    <UserControl.Resources>
        <!-- Color cycle for Stop1 -->
        <Storyboard x:Key="GradientColorCycle">
            <ColorAnimation Storyboard.TargetName="Stop1"
                            Storyboard.TargetProperty="Color"
                            From="#667eea" To="#f093fb"
                            Duration="0:0:4" AutoReverse="True"
                            RepeatBehavior="Forever"/>
            <ColorAnimation Storyboard.TargetName="Stop2"
                            Storyboard.TargetProperty="Color"
                            From="#764ba2" To="#667eea"
                            Duration="0:0:4" AutoReverse="True"
                            RepeatBehavior="Forever"/>
            <ColorAnimation Storyboard.TargetName="Stop3"
                            Storyboard.TargetProperty="Color"
                            From="#f093fb" To="#764ba2"
                            Duration="0:0:4" AutoReverse="True"
                            RepeatBehavior="Forever"/>
            <DoubleAnimation Storyboard.TargetName="Stop2"
                             Storyboard.TargetProperty="Offset"
                             From="0.3" To="0.7"
                             Duration="0:0:4" AutoReverse="True"
                             RepeatBehavior="Forever"/>
        </Storyboard>

        <!-- ★ DemoSequence
             원본 의도: 그라데이션 배경이 무한 루프로 색상을 순환하는 배경 애니메이션
             시나리오: 3개 GradientStop 색상이 동시에 변화(0~4s, 왕복)
                       → Stop1: #667eea → #f093fb, Stop2: #764ba2 → #667eea, Stop3: #f093fb → #764ba2
                       → 중간 Stop의 Offset도 0.3 ↔ 0.7 사이 이동
                       → 4초 왕복 1회로 전체 색상 순환을 보여줌
             핵심 기법: ColorAnimation으로 GradientStop.Color 변경,
                        DoubleAnimation으로 GradientStop.Offset 이동,
                        AutoReverse로 자연스러운 왕복
             다른 플랫폼:
               - 웹: CSS @keyframes + background linear-gradient 또는 hue-rotate filter
               - 모바일: CAGradientLayer 애니메이션(iOS), GradientDrawable + ValueAnimator(Android)
        -->
        <Storyboard x:Key="DemoSequence">
            <!-- Phase 1: Color cycle forward (0~4s) -->
            <ColorAnimation Storyboard.TargetName="Stop1"
                            Storyboard.TargetProperty="Color"
                            From="#667eea" To="#f093fb"
                            Duration="0:0:4"
                            BeginTime="0:0:0" FillBehavior="HoldEnd"/>
            <ColorAnimation Storyboard.TargetName="Stop2"
                            Storyboard.TargetProperty="Color"
                            From="#764ba2" To="#667eea"
                            Duration="0:0:4"
                            BeginTime="0:0:0" FillBehavior="HoldEnd"/>
            <ColorAnimation Storyboard.TargetName="Stop3"
                            Storyboard.TargetProperty="Color"
                            From="#f093fb" To="#764ba2"
                            Duration="0:0:4"
                            BeginTime="0:0:0" FillBehavior="HoldEnd"/>
            <DoubleAnimation Storyboard.TargetName="Stop2"
                             Storyboard.TargetProperty="Offset"
                             From="0.3" To="0.7"
                             Duration="0:0:4"
                             BeginTime="0:0:0" FillBehavior="HoldEnd"/>

            <!-- Phase 2: Color cycle reverse (4.5~8.5s) -->
            <ColorAnimation Storyboard.TargetName="Stop1"
                            Storyboard.TargetProperty="Color"
                            From="#f093fb" To="#667eea"
                            Duration="0:0:4"
                            BeginTime="0:0:4.5" FillBehavior="HoldEnd"/>
            <ColorAnimation Storyboard.TargetName="Stop2"
                            Storyboard.TargetProperty="Color"
                            From="#667eea" To="#764ba2"
                            Duration="0:0:4"
                            BeginTime="0:0:4.5" FillBehavior="HoldEnd"/>
            <ColorAnimation Storyboard.TargetName="Stop3"
                            Storyboard.TargetProperty="Color"
                            From="#764ba2" To="#f093fb"
                            Duration="0:0:4"
                            BeginTime="0:0:4.5" FillBehavior="HoldEnd"/>
            <DoubleAnimation Storyboard.TargetName="Stop2"
                             Storyboard.TargetProperty="Offset"
                             From="0.7" To="0.3"
                             Duration="0:0:4"
                             BeginTime="0:0:4.5" FillBehavior="HoldEnd"/>
        </Storyboard>
    </UserControl.Resources>

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <!-- Stop 1: #667eea -> #f093fb -->
                    <ColorAnimation Storyboard.TargetName="Stop1"
                                    Storyboard.TargetProperty="Color"
                                    From="#667eea" To="#f093fb"
                                    Duration="0:0:4" AutoReverse="True"
                                    RepeatBehavior="Forever"/>

                    <!-- Stop 2: #764ba2 -> #667eea -->
                    <ColorAnimation Storyboard.TargetName="Stop2"
                                    Storyboard.TargetProperty="Color"
                                    From="#764ba2" To="#667eea"
                                    Duration="0:0:4" AutoReverse="True"
                                    RepeatBehavior="Forever"/>

                    <!-- Stop 3: #f093fb -> #764ba2 -->
                    <ColorAnimation Storyboard.TargetName="Stop3"
                                    Storyboard.TargetProperty="Color"
                                    From="#f093fb" To="#764ba2"
                                    Duration="0:0:4" AutoReverse="True"
                                    RepeatBehavior="Forever"/>

                    <!-- Middle stop offset animation 0.3 <-> 0.7 -->
                    <DoubleAnimation Storyboard.TargetName="Stop2"
                                     Storyboard.TargetProperty="Offset"
                                     From="0.3" To="0.7"
                                     Duration="0:0:4" AutoReverse="True"
                                     RepeatBehavior="Forever"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>

    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <!-- Glass card overlay -->
            <Border CornerRadius="16" Padding="40,30"
                    Width="400">
                <Border.Background>
                    <SolidColorBrush Color="#1E1E2E" Opacity="0.6"/>
                </Border.Background>
                <StackPanel>
                    <TextBlock Text="Animated Gradient" FontSize="32" FontWeight="Bold"
                               Foreground="White" HorizontalAlignment="Center"/>
                    <TextBlock Text="Background" FontSize="32" FontWeight="Light"
                               Foreground="#E0E0E0" HorizontalAlignment="Center" Margin="0,-4,0,0"/>
                    <TextBlock FontSize="14" Foreground="#B0B0C0" TextAlignment="Center"
                               Margin="0,16,0,0" TextWrapping="Wrap"
                               Text="Three gradient stops animate their colors continuously while the middle stop shifts its offset between 0.3 and 0.7."/>

                    <Border Background="#FFFFFF" Opacity="0.15" CornerRadius="8"
                            Height="4" Margin="40,20,40,0"/>

                    <WrapPanel HorizontalAlignment="Center" Margin="0,20,0,0">
                        <Border CornerRadius="6" Padding="12,6" Margin="4">
                            <Border.Background>
                                <SolidColorBrush Color="White" Opacity="0.15"/>
                            </Border.Background>
                            <TextBlock Text="4s Duration" Foreground="White" FontSize="12"/>
                        </Border>
                        <Border CornerRadius="6" Padding="12,6" Margin="4">
                            <Border.Background>
                                <SolidColorBrush Color="White" Opacity="0.15"/>
                            </Border.Background>
                            <TextBlock Text="AutoReverse" Foreground="White" FontSize="12"/>
                        </Border>
                        <Border CornerRadius="6" Padding="12,6" Margin="4">
                            <Border.Background>
                                <SolidColorBrush Color="White" Opacity="0.15"/>
                            </Border.Background>
                            <TextBlock Text="Forever" Foreground="White" FontSize="12"/>
                        </Border>
                    </WrapPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
