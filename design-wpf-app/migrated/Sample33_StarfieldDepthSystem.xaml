<UserControl x:Class="design_wpf_app.Migrated.Sample33_StarfieldDepthSystem"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800"
             Background="#030712">
    <Grid>
        <Canvas x:Name="bgStars" ClipToBounds="True">
            <Ellipse Width="1" Height="1" Fill="#FFFFFF15" Canvas.Left="50" Canvas.Top="100"/>
            <Ellipse Width="1.5" Height="1.5" Fill="#FFFFFF20" Canvas.Left="200" Canvas.Top="50"/>
            <Ellipse Width="1" Height="1" Fill="#FFFFFF10" Canvas.Left="400" Canvas.Top="200"/>
            <Ellipse Width="2" Height="2" Fill="#FFFFFF18" Canvas.Left="600" Canvas.Top="80"/>
            <Ellipse Width="1" Height="1" Fill="#FFFFFF12" Canvas.Left="350" Canvas.Top="300"/>
        </Canvas>
        <Canvas x:Name="midStars" ClipToBounds="True">
            <Ellipse Width="2" Height="2" Fill="#FFFFFF30" Canvas.Left="100" Canvas.Top="150">
                <Ellipse.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(Canvas.Left)" From="100" To="-10" Duration="0:0:12" RepeatBehavior="Forever"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Ellipse.Triggers>
            </Ellipse>
            <Ellipse Width="3" Height="3" Fill="#FFFFFF40" Canvas.Left="500" Canvas.Top="250">
                <Ellipse.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(Canvas.Left)" From="500" To="-10" Duration="0:0:10" RepeatBehavior="Forever"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Ellipse.Triggers>
            </Ellipse>
        </Canvas>
        <Canvas x:Name="fgStars" ClipToBounds="True">
            <Ellipse Width="5" Height="5" Fill="#FFFFFF90" Canvas.Left="300" Canvas.Top="200">
                <Ellipse.Effect><DropShadowEffect ShadowDepth="0" BlurRadius="12" Color="White" Opacity="0.6"/></Ellipse.Effect>
                <Ellipse.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(Canvas.Left)" From="800" To="-10" Duration="0:0:6" RepeatBehavior="Forever"/>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.9" To="0.3" Duration="0:0:6" RepeatBehavior="Forever"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Ellipse.Triggers>
            </Ellipse>
            <Ellipse Width="4" Height="4" Fill="#8B5CF690" Canvas.Left="700" Canvas.Top="100">
                <Ellipse.Effect><DropShadowEffect ShadowDepth="0" BlurRadius="10" Color="#8B5CF6" Opacity="0.5"/></Ellipse.Effect>
                <Ellipse.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(Canvas.Left)" From="800" To="-10" Duration="0:0:5" BeginTime="0:0:1" RepeatBehavior="Forever"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Ellipse.Triggers>
            </Ellipse>
        </Canvas>
    </Grid>
</UserControl>
