<UserControl x:Class="design_wpf_app.Migrated.Sample19_PetalScatterWind"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800"
             Background="#0A0F1C">

    <UserControl.Resources>
        <!-- PetalA Wind Blow -->
        <Storyboard x:Key="PetalAWind" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="PetalATranslate"
                             Storyboard.TargetProperty="X"
                             From="0" To="900" Duration="0:0:5"/>
            <DoubleAnimation Storyboard.TargetName="PetalATranslate"
                             Storyboard.TargetProperty="Y"
                             From="0" To="200" Duration="0:0:5"/>
            <DoubleAnimation Storyboard.TargetName="PetalARotate"
                             Storyboard.TargetProperty="Angle"
                             From="0" To="540" Duration="0:0:5"/>
            <DoubleAnimation Storyboard.TargetName="PetalAScale"
                             Storyboard.TargetProperty="ScaleX"
                             From="1" To="0.3" Duration="0:0:5"/>
            <DoubleAnimation Storyboard.TargetName="PetalAScale"
                             Storyboard.TargetProperty="ScaleY"
                             From="1" To="0.3" Duration="0:0:5"/>
            <DoubleAnimation Storyboard.TargetName="PetalA"
                             Storyboard.TargetProperty="Opacity"
                             From="0.9" To="0" Duration="0:0:5"/>
        </Storyboard>

        <!-- PetalB Wind Blow -->
        <Storyboard x:Key="PetalBWind" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="PetalBTranslate"
                             Storyboard.TargetProperty="X"
                             From="0" To="850" Duration="0:0:6" BeginTime="0:0:1"/>
            <DoubleAnimation Storyboard.TargetName="PetalBTranslate"
                             Storyboard.TargetProperty="Y"
                             From="0" To="150" Duration="0:0:6" BeginTime="0:0:1"/>
            <DoubleAnimation Storyboard.TargetName="PetalBRotate"
                             Storyboard.TargetProperty="Angle"
                             From="0" To="-720" Duration="0:0:6" BeginTime="0:0:1"/>
            <DoubleAnimation Storyboard.TargetName="PetalBScale"
                             Storyboard.TargetProperty="ScaleX"
                             From="1" To="0.2" Duration="0:0:6" BeginTime="0:0:1"/>
            <DoubleAnimation Storyboard.TargetName="PetalBScale"
                             Storyboard.TargetProperty="ScaleY"
                             From="1" To="0.2" Duration="0:0:6" BeginTime="0:0:1"/>
            <DoubleAnimation Storyboard.TargetName="PetalB"
                             Storyboard.TargetProperty="Opacity"
                             From="0.8" To="0" Duration="0:0:6" BeginTime="0:0:1"/>
        </Storyboard>

        <!-- PetalC Wind Blow -->
        <Storyboard x:Key="PetalCWind" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="PetalCTranslate"
                             Storyboard.TargetProperty="X"
                             From="0" To="950" Duration="0:0:7" BeginTime="0:0:2"/>
            <DoubleAnimation Storyboard.TargetName="PetalCTranslate"
                             Storyboard.TargetProperty="Y"
                             From="0" To="-80" Duration="0:0:7" BeginTime="0:0:2"/>
            <DoubleAnimation Storyboard.TargetName="PetalCRotate"
                             Storyboard.TargetProperty="Angle"
                             From="0" To="900" Duration="0:0:7" BeginTime="0:0:2"/>
            <DoubleAnimation Storyboard.TargetName="PetalCScale"
                             Storyboard.TargetProperty="ScaleX"
                             From="1" To="0.15" Duration="0:0:7" BeginTime="0:0:2"/>
            <DoubleAnimation Storyboard.TargetName="PetalCScale"
                             Storyboard.TargetProperty="ScaleY"
                             From="1" To="0.15" Duration="0:0:7" BeginTime="0:0:2"/>
            <DoubleAnimation Storyboard.TargetName="PetalC"
                             Storyboard.TargetProperty="Opacity"
                             From="0.75" To="0" Duration="0:0:7" BeginTime="0:0:2"/>
        </Storyboard>

        <!-- ★ DemoSequence
             원본 의도: 꽃잎 바람 흩날림 — 3개의 꽃잎이 왼쪽에서 바람에 불려 오른쪽으로 날아감
             시나리오: PetalA(#FFB7C5) 즉시 출발(X 0→900, Y 0→200 하향, 540도 텀블링, 축소 1→0.3, 페이드아웃)
                       → 1s 후 PetalB(#FF91A4, X 0→850, Y 0→150, -720도 역회전, 축소 1→0.2)
                       → 2s 후 PetalC(#FFD1DC, X 0→950, Y 0→-80 상향 아크, 900도 회전, 축소 1→0.15)
                       각 꽃잎 1사이클 후 HoldEnd
             핵심 기법: TranslateTransform X(바람 이동) + Y(수직 드리프트) + RotateTransform(텀블링)
                        + ScaleTransform(원근 축소) + Opacity 페이드아웃, BeginTime 스태거
             다른 플랫폼:
               - 웹: CSS transform: translate + rotate + scale keyframes, 또는 GSAP timeline
               - 모바일: UIView.animate(iOS) transforms 조합, Android ObjectAnimator PropertyValuesHolder 복합 애니메이션
        -->
        <Storyboard x:Key="DemoSequence">
            <!-- PetalA: blow right 5s, begin at 0s -->
            <DoubleAnimation Storyboard.TargetName="PetalATranslate"
                             Storyboard.TargetProperty="X"
                             From="0" To="900" Duration="0:0:5"
                             BeginTime="0:0:0" FillBehavior="HoldEnd"/>
            <DoubleAnimation Storyboard.TargetName="PetalATranslate"
                             Storyboard.TargetProperty="Y"
                             From="0" To="200" Duration="0:0:5"
                             BeginTime="0:0:0" FillBehavior="HoldEnd"/>
            <DoubleAnimation Storyboard.TargetName="PetalARotate"
                             Storyboard.TargetProperty="Angle"
                             From="0" To="540" Duration="0:0:5"
                             BeginTime="0:0:0" FillBehavior="HoldEnd"/>
            <DoubleAnimation Storyboard.TargetName="PetalAScale"
                             Storyboard.TargetProperty="ScaleX"
                             From="1" To="0.3" Duration="0:0:5"
                             BeginTime="0:0:0" FillBehavior="HoldEnd"/>
            <DoubleAnimation Storyboard.TargetName="PetalAScale"
                             Storyboard.TargetProperty="ScaleY"
                             From="1" To="0.3" Duration="0:0:5"
                             BeginTime="0:0:0" FillBehavior="HoldEnd"/>
            <DoubleAnimation Storyboard.TargetName="PetalA"
                             Storyboard.TargetProperty="Opacity"
                             From="0.9" To="0" Duration="0:0:5"
                             BeginTime="0:0:0" FillBehavior="HoldEnd"/>

            <!-- PetalB: blow right 6s, begin at 1s -->
            <DoubleAnimation Storyboard.TargetName="PetalBTranslate"
                             Storyboard.TargetProperty="X"
                             From="0" To="850" Duration="0:0:6"
                             BeginTime="0:0:1" FillBehavior="HoldEnd"/>
            <DoubleAnimation Storyboard.TargetName="PetalBTranslate"
                             Storyboard.TargetProperty="Y"
                             From="0" To="150" Duration="0:0:6"
                             BeginTime="0:0:1" FillBehavior="HoldEnd"/>
            <DoubleAnimation Storyboard.TargetName="PetalBRotate"
                             Storyboard.TargetProperty="Angle"
                             From="0" To="-720" Duration="0:0:6"
                             BeginTime="0:0:1" FillBehavior="HoldEnd"/>
            <DoubleAnimation Storyboard.TargetName="PetalBScale"
                             Storyboard.TargetProperty="ScaleX"
                             From="1" To="0.2" Duration="0:0:6"
                             BeginTime="0:0:1" FillBehavior="HoldEnd"/>
            <DoubleAnimation Storyboard.TargetName="PetalBScale"
                             Storyboard.TargetProperty="ScaleY"
                             From="1" To="0.2" Duration="0:0:6"
                             BeginTime="0:0:1" FillBehavior="HoldEnd"/>
            <DoubleAnimation Storyboard.TargetName="PetalB"
                             Storyboard.TargetProperty="Opacity"
                             From="0.8" To="0" Duration="0:0:6"
                             BeginTime="0:0:1" FillBehavior="HoldEnd"/>

            <!-- PetalC: blow right 7s, begin at 2s -->
            <DoubleAnimation Storyboard.TargetName="PetalCTranslate"
                             Storyboard.TargetProperty="X"
                             From="0" To="950" Duration="0:0:7"
                             BeginTime="0:0:2" FillBehavior="HoldEnd"/>
            <DoubleAnimation Storyboard.TargetName="PetalCTranslate"
                             Storyboard.TargetProperty="Y"
                             From="0" To="-80" Duration="0:0:7"
                             BeginTime="0:0:2" FillBehavior="HoldEnd"/>
            <DoubleAnimation Storyboard.TargetName="PetalCRotate"
                             Storyboard.TargetProperty="Angle"
                             From="0" To="900" Duration="0:0:7"
                             BeginTime="0:0:2" FillBehavior="HoldEnd"/>
            <DoubleAnimation Storyboard.TargetName="PetalCScale"
                             Storyboard.TargetProperty="ScaleX"
                             From="1" To="0.15" Duration="0:0:7"
                             BeginTime="0:0:2" FillBehavior="HoldEnd"/>
            <DoubleAnimation Storyboard.TargetName="PetalCScale"
                             Storyboard.TargetProperty="ScaleY"
                             From="1" To="0.15" Duration="0:0:7"
                             BeginTime="0:0:2" FillBehavior="HoldEnd"/>
            <DoubleAnimation Storyboard.TargetName="PetalC"
                             Storyboard.TargetProperty="Opacity"
                             From="0.75" To="0" Duration="0:0:7"
                             BeginTime="0:0:2" FillBehavior="HoldEnd"/>
        </Storyboard>
    </UserControl.Resources>

    <Canvas x:Name="WindCanvas" ClipToBounds="True">

        <!-- Petal A: blown right-downward -->
        <Path x:Name="PetalA" Canvas.Left="-20" Canvas.Top="100"
              Data="M8 0 C12 3 16 9 12 15 C10 18 6 18 4 15 C0 9 4 3 8 0 Z"
              Fill="#FFB7C5" Opacity="0.9" RenderTransformOrigin="0.5,0.5">
            <Path.RenderTransform>
                <TransformGroup>
                    <TranslateTransform x:Name="PetalATranslate"/>
                    <RotateTransform x:Name="PetalARotate"/>
                    <ScaleTransform x:Name="PetalAScale"/>
                </TransformGroup>
            </Path.RenderTransform>
            <Path.Triggers>
                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                    <BeginStoryboard>
                        <Storyboard RepeatBehavior="Forever">
                            <DoubleAnimation
                                Storyboard.TargetName="PetalATranslate"
                                Storyboard.TargetProperty="X"
                                From="0" To="900" Duration="0:0:5"/>
                            <DoubleAnimation
                                Storyboard.TargetName="PetalATranslate"
                                Storyboard.TargetProperty="Y"
                                From="0" To="200" Duration="0:0:5"/>
                            <DoubleAnimation
                                Storyboard.TargetName="PetalARotate"
                                Storyboard.TargetProperty="Angle"
                                From="0" To="540" Duration="0:0:5"/>
                            <DoubleAnimation
                                Storyboard.TargetName="PetalAScale"
                                Storyboard.TargetProperty="ScaleX"
                                From="1" To="0.3" Duration="0:0:5"/>
                            <DoubleAnimation
                                Storyboard.TargetName="PetalAScale"
                                Storyboard.TargetProperty="ScaleY"
                                From="1" To="0.3" Duration="0:0:5"/>
                            <DoubleAnimation
                                Storyboard.TargetProperty="Opacity"
                                From="0.9" To="0" Duration="0:0:5"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Path.Triggers>
        </Path>

        <!-- Petal B: blown with different trajectory -->
        <Path x:Name="PetalB" Canvas.Left="-30" Canvas.Top="250"
              Data="M6 0 C9 2 12 7 9 12 C8 14 4 14 3 12 C0 7 3 2 6 0 Z"
              Fill="#FF91A4" Opacity="0.8" RenderTransformOrigin="0.5,0.5">
            <Path.RenderTransform>
                <TransformGroup>
                    <TranslateTransform x:Name="PetalBTranslate"/>
                    <RotateTransform x:Name="PetalBRotate"/>
                    <ScaleTransform x:Name="PetalBScale"/>
                </TransformGroup>
            </Path.RenderTransform>
            <Path.Triggers>
                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                    <BeginStoryboard>
                        <Storyboard RepeatBehavior="Forever">
                            <DoubleAnimation
                                Storyboard.TargetName="PetalBTranslate"
                                Storyboard.TargetProperty="X"
                                From="0" To="850" Duration="0:0:6"
                                BeginTime="0:0:1"/>
                            <DoubleAnimation
                                Storyboard.TargetName="PetalBTranslate"
                                Storyboard.TargetProperty="Y"
                                From="0" To="150" Duration="0:0:6"
                                BeginTime="0:0:1"/>
                            <DoubleAnimation
                                Storyboard.TargetName="PetalBRotate"
                                Storyboard.TargetProperty="Angle"
                                From="0" To="-720" Duration="0:0:6"
                                BeginTime="0:0:1"/>
                            <DoubleAnimation
                                Storyboard.TargetName="PetalBScale"
                                Storyboard.TargetProperty="ScaleX"
                                From="1" To="0.2" Duration="0:0:6"
                                BeginTime="0:0:1"/>
                            <DoubleAnimation
                                Storyboard.TargetName="PetalBScale"
                                Storyboard.TargetProperty="ScaleY"
                                From="1" To="0.2" Duration="0:0:6"
                                BeginTime="0:0:1"/>
                            <DoubleAnimation
                                Storyboard.TargetProperty="Opacity"
                                From="0.8" To="0" Duration="0:0:6"
                                BeginTime="0:0:1"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Path.Triggers>
        </Path>

        <!-- Petal C: higher arc -->
        <Path x:Name="PetalC" Canvas.Left="-10" Canvas.Top="400"
              Data="M7 0 C10.5 2.5 14 8 10.5 13 C9 15 5 15 3.5 13 C0 8 3.5 2.5 7 0 Z"
              Fill="#FFD1DC" Opacity="0.75" RenderTransformOrigin="0.5,0.5">
            <Path.RenderTransform>
                <TransformGroup>
                    <TranslateTransform x:Name="PetalCTranslate"/>
                    <RotateTransform x:Name="PetalCRotate"/>
                    <ScaleTransform x:Name="PetalCScale"/>
                </TransformGroup>
            </Path.RenderTransform>
            <Path.Triggers>
                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                    <BeginStoryboard>
                        <Storyboard RepeatBehavior="Forever">
                            <DoubleAnimation
                                Storyboard.TargetName="PetalCTranslate"
                                Storyboard.TargetProperty="X"
                                From="0" To="950" Duration="0:0:7"
                                BeginTime="0:0:2"/>
                            <DoubleAnimation
                                Storyboard.TargetName="PetalCTranslate"
                                Storyboard.TargetProperty="Y"
                                From="0" To="-80" Duration="0:0:7"
                                BeginTime="0:0:2"/>
                            <DoubleAnimation
                                Storyboard.TargetName="PetalCRotate"
                                Storyboard.TargetProperty="Angle"
                                From="0" To="900" Duration="0:0:7"
                                BeginTime="0:0:2"/>
                            <DoubleAnimation
                                Storyboard.TargetName="PetalCScale"
                                Storyboard.TargetProperty="ScaleX"
                                From="1" To="0.15" Duration="0:0:7"
                                BeginTime="0:0:2"/>
                            <DoubleAnimation
                                Storyboard.TargetName="PetalCScale"
                                Storyboard.TargetProperty="ScaleY"
                                From="1" To="0.15" Duration="0:0:7"
                                BeginTime="0:0:2"/>
                            <DoubleAnimation
                                Storyboard.TargetProperty="Opacity"
                                From="0.75" To="0" Duration="0:0:7"
                                BeginTime="0:0:2"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Path.Triggers>
        </Path>

    </Canvas>
</UserControl>
