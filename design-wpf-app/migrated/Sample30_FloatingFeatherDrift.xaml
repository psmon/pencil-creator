<UserControl x:Class="design_wpf_app.Migrated.Sample30_FloatingFeatherDrift"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="400"
             Background="#0A0F1C">
    <Canvas ClipToBounds="True">
        <Path Canvas.Left="180" Canvas.Top="-40" Opacity="0.8"
              Fill="#22D3EE" RenderTransformOrigin="0.5,0.5">
            <Path.Data>
                <PathGeometry>
                    <PathFigure StartPoint="20,0" IsClosed="True">
                        <BezierSegment Point1="15,20" Point2="5,40" Point3="10,60"/>
                        <BezierSegment Point1="13,70" Point2="18,75" Point3="20,80"/>
                        <BezierSegment Point1="22,75" Point2="27,70" Point3="30,60"/>
                        <BezierSegment Point1="35,40" Point2="25,20" Point3="20,0"/>
                    </PathFigure>
                    <PathFigure StartPoint="20,0" IsClosed="False">
                        <LineSegment Point="20,80"/>
                    </PathFigure>
                </PathGeometry>
            </Path.Data>
            <Path.RenderTransform>
                <TransformGroup>
                    <TranslateTransform x:Name="featherTranslateX"/>
                    <TranslateTransform x:Name="featherTranslateY"/>
                    <RotateTransform x:Name="featherRotate" CenterX="20" CenterY="40"/>
                </TransformGroup>
            </Path.RenderTransform>
            <Path.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetName="featherTranslateX" Storyboard.TargetProperty="X"
                                             From="-30" To="30" Duration="0:0:3" AutoReverse="True" RepeatBehavior="Forever">
                                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation Storyboard.TargetName="featherTranslateY" Storyboard.TargetProperty="Y"
                                             From="0" To="500" Duration="0:0:8" RepeatBehavior="Forever"/>
                            <DoubleAnimation Storyboard.TargetName="featherRotate" Storyboard.TargetProperty="Angle"
                                             From="-15" To="15" Duration="0:0:2.5" AutoReverse="True" RepeatBehavior="Forever">
                                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.8" To="0.1" Duration="0:0:8" RepeatBehavior="Forever"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Path.Triggers>
        </Path>
    </Canvas>
</UserControl>
