<UserControl x:Class="design_wpf_app.Migrated.Sample09_SnackbarToast"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="600"
             Background="#1E1E2E">

    <UserControl.Resources>
        <!-- Default Snackbar Show -->
        <Storyboard x:Key="ShowDefaultSnackbar">
            <DoubleAnimation Storyboard.TargetName="defaultSnackbarTranslate"
                Storyboard.TargetProperty="Y"
                From="60" To="0" Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="defaultSnackbar"
                Storyboard.TargetProperty="Opacity"
                From="0" To="1" Duration="0:0:0.3" />
        </Storyboard>

        <!-- Default Snackbar Hide (auto after 3s) -->
        <Storyboard x:Key="HideDefaultSnackbar">
            <DoubleAnimation Storyboard.TargetName="defaultSnackbarTranslate"
                Storyboard.TargetProperty="Y"
                From="0" To="60" Duration="0:0:0.3"
                BeginTime="0:0:3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="defaultSnackbar"
                Storyboard.TargetProperty="Opacity"
                From="1" To="0" Duration="0:0:0.3"
                BeginTime="0:0:3" />
        </Storyboard>

        <!-- Success Snackbar Show -->
        <Storyboard x:Key="ShowSuccessSnackbar">
            <DoubleAnimation Storyboard.TargetName="successSnackbarTranslate"
                Storyboard.TargetProperty="Y"
                From="60" To="0" Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="successSnackbar"
                Storyboard.TargetProperty="Opacity"
                From="0" To="1" Duration="0:0:0.3" />
        </Storyboard>

        <!-- Success Snackbar Hide -->
        <Storyboard x:Key="HideSuccessSnackbar">
            <DoubleAnimation Storyboard.TargetName="successSnackbarTranslate"
                Storyboard.TargetProperty="Y"
                From="0" To="60" Duration="0:0:0.3"
                BeginTime="0:0:3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="successSnackbar"
                Storyboard.TargetProperty="Opacity"
                From="1" To="0" Duration="0:0:0.3"
                BeginTime="0:0:3" />
        </Storyboard>

        <!-- Error Snackbar Show -->
        <Storyboard x:Key="ShowErrorSnackbar">
            <DoubleAnimation Storyboard.TargetName="errorSnackbarTranslate"
                Storyboard.TargetProperty="Y"
                From="60" To="0" Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="errorSnackbar"
                Storyboard.TargetProperty="Opacity"
                From="0" To="1" Duration="0:0:0.3" />
        </Storyboard>

        <!-- Error Snackbar Hide -->
        <Storyboard x:Key="HideErrorSnackbar">
            <DoubleAnimation Storyboard.TargetName="errorSnackbarTranslate"
                Storyboard.TargetProperty="Y"
                From="0" To="60" Duration="0:0:0.3"
                BeginTime="0:0:3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="errorSnackbar"
                Storyboard.TargetProperty="Opacity"
                From="1" To="0" Duration="0:0:0.3"
                BeginTime="0:0:3" />
        </Storyboard>

        <!-- ★ DemoSequence
             원본 의도: 스낵바/토스트 알림 — 하단에서 슬라이드업 + 페이드인, 3초 후 자동 사라짐
             시나리오: 기본 스낵바 표시(슬라이드업+페이드인) → 3초 후 자동 사라짐(슬라이드다운+페이드아웃)
                       → 성공 스낵바 표시 → 3초 후 자동 사라짐
             핵심 기법: TranslateTransform.Y(60→0 슬라이드), Opacity(페이드),
                        BeginTime으로 3초 후 자동 숨김 타이밍 제어
             다른 플랫폼:
               - 웹: CSS transform: translateY() + opacity transition, setTimeout으로 자동 제거
               - 모바일: 네이티브 Snackbar/Toast API, 커스텀 시 bottom 애니메이션
        -->
        <Storyboard x:Key="DemoSequence">
            <!-- Phase 1: Show default snackbar (0~0.4s) -->
            <DoubleAnimation Storyboard.TargetName="defaultSnackbarTranslate"
                Storyboard.TargetProperty="Y"
                From="60" To="0" Duration="0:0:0.4"
                BeginTime="0:0:0" FillBehavior="HoldEnd">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="defaultSnackbar"
                Storyboard.TargetProperty="Opacity"
                From="0" To="1" Duration="0:0:0.3"
                BeginTime="0:0:0" FillBehavior="HoldEnd" />

            <!-- Phase 2: Hide default snackbar (3~3.3s) -->
            <DoubleAnimation Storyboard.TargetName="defaultSnackbarTranslate"
                Storyboard.TargetProperty="Y"
                To="60" Duration="0:0:0.3"
                BeginTime="0:0:3" FillBehavior="HoldEnd">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="defaultSnackbar"
                Storyboard.TargetProperty="Opacity"
                To="0" Duration="0:0:0.3"
                BeginTime="0:0:3" FillBehavior="HoldEnd" />

            <!-- Phase 3: Show success snackbar (4~4.4s) -->
            <DoubleAnimation Storyboard.TargetName="successSnackbarTranslate"
                Storyboard.TargetProperty="Y"
                From="60" To="0" Duration="0:0:0.4"
                BeginTime="0:0:4" FillBehavior="HoldEnd">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="successSnackbar"
                Storyboard.TargetProperty="Opacity"
                From="0" To="1" Duration="0:0:0.3"
                BeginTime="0:0:4" FillBehavior="HoldEnd" />

            <!-- Phase 4: Hide success snackbar (7~7.3s) -->
            <DoubleAnimation Storyboard.TargetName="successSnackbarTranslate"
                Storyboard.TargetProperty="Y"
                To="60" Duration="0:0:0.3"
                BeginTime="0:0:7" FillBehavior="HoldEnd">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="successSnackbar"
                Storyboard.TargetProperty="Opacity"
                To="0" Duration="0:0:0.3"
                BeginTime="0:0:7" FillBehavior="HoldEnd" />
        </Storyboard>

        <Style x:Key="SnackbarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <!-- Trigger Buttons -->
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Top"
                    Margin="0,30,0,0" Orientation="Horizontal">
            <Button x:Name="btnDefault" Content="Default"
                    Style="{StaticResource SnackbarButtonStyle}"
                    Background="#475569" Margin="0,0,10,0">
                <Button.Triggers>
                    <EventTrigger RoutedEvent="Button.Click">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="defaultSnackbarTranslate"
                                    Storyboard.TargetProperty="Y"
                                    From="60" To="0" Duration="0:0:0.4">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut" />
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetName="defaultSnackbar"
                                    Storyboard.TargetProperty="Opacity"
                                    From="0" To="1" Duration="0:0:0.3" />
                                <DoubleAnimation Storyboard.TargetName="defaultSnackbarTranslate"
                                    Storyboard.TargetProperty="Y"
                                    To="60" Duration="0:0:0.3" BeginTime="0:0:3">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseIn" />
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetName="defaultSnackbar"
                                    Storyboard.TargetProperty="Opacity"
                                    To="0" Duration="0:0:0.3" BeginTime="0:0:3" />
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Button.Triggers>
            </Button>

            <Button x:Name="btnSuccess" Content="Success"
                    Style="{StaticResource SnackbarButtonStyle}"
                    Background="#22C55E" Margin="0,0,10,0">
                <Button.Triggers>
                    <EventTrigger RoutedEvent="Button.Click">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="successSnackbarTranslate"
                                    Storyboard.TargetProperty="Y"
                                    From="60" To="0" Duration="0:0:0.4">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut" />
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetName="successSnackbar"
                                    Storyboard.TargetProperty="Opacity"
                                    From="0" To="1" Duration="0:0:0.3" />
                                <DoubleAnimation Storyboard.TargetName="successSnackbarTranslate"
                                    Storyboard.TargetProperty="Y"
                                    To="60" Duration="0:0:0.3" BeginTime="0:0:3">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseIn" />
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetName="successSnackbar"
                                    Storyboard.TargetProperty="Opacity"
                                    To="0" Duration="0:0:0.3" BeginTime="0:0:3" />
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Button.Triggers>
            </Button>

            <Button x:Name="btnError" Content="Error"
                    Style="{StaticResource SnackbarButtonStyle}"
                    Background="#EF4444">
                <Button.Triggers>
                    <EventTrigger RoutedEvent="Button.Click">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="errorSnackbarTranslate"
                                    Storyboard.TargetProperty="Y"
                                    From="60" To="0" Duration="0:0:0.4">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut" />
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetName="errorSnackbar"
                                    Storyboard.TargetProperty="Opacity"
                                    From="0" To="1" Duration="0:0:0.3" />
                                <DoubleAnimation Storyboard.TargetName="errorSnackbarTranslate"
                                    Storyboard.TargetProperty="Y"
                                    To="60" Duration="0:0:0.3" BeginTime="0:0:3">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseIn" />
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetName="errorSnackbar"
                                    Storyboard.TargetProperty="Opacity"
                                    To="0" Duration="0:0:0.3" BeginTime="0:0:3" />
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Button.Triggers>
            </Button>
        </StackPanel>

        <!-- Snackbar Container (bottom) -->
        <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Center"
                    Margin="0,0,0,30">

            <!-- Default Snackbar -->
            <Border x:Name="defaultSnackbar" Opacity="0"
                    Background="#334155" CornerRadius="8"
                    Padding="20,14" Margin="0,0,0,10"
                    MinWidth="350">
                <Border.RenderTransform>
                    <TranslateTransform x:Name="defaultSnackbarTranslate" Y="60" />
                </Border.RenderTransform>
                <TextBlock Text="This is a default notification."
                           Foreground="White" FontSize="14" />
            </Border>

            <!-- Success Snackbar -->
            <Border x:Name="successSnackbar" Opacity="0"
                    Background="#166534" CornerRadius="8"
                    Padding="20,14" Margin="0,0,0,10"
                    MinWidth="350">
                <Border.RenderTransform>
                    <TranslateTransform x:Name="successSnackbarTranslate" Y="60" />
                </Border.RenderTransform>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#x2714;" Foreground="#86EFAC" FontSize="16"
                               Margin="0,0,10,0" VerticalAlignment="Center" />
                    <TextBlock Text="Operation completed successfully!"
                               Foreground="White" FontSize="14" />
                </StackPanel>
            </Border>

            <!-- Error Snackbar -->
            <Border x:Name="errorSnackbar" Opacity="0"
                    Background="#7F1D1D" CornerRadius="8"
                    Padding="20,14"
                    MinWidth="350">
                <Border.RenderTransform>
                    <TranslateTransform x:Name="errorSnackbarTranslate" Y="60" />
                </Border.RenderTransform>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#x2716;" Foreground="#FCA5A5" FontSize="16"
                               Margin="0,0,10,0" VerticalAlignment="Center" />
                    <TextBlock Text="Something went wrong. Please try again."
                               Foreground="White" FontSize="14" />
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
