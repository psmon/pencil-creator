<UserControl x:Class="design_wpf_app.Migrated.Sample28_ZenBreathingCircle"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="400"
             Background="#0A0F1C">
    <Grid>
        <Ellipse Width="200" Height="200" HorizontalAlignment="Center" VerticalAlignment="Center"
                 Fill="#1522D3EE" Stroke="#4022D3EE" StrokeThickness="1"
                 RenderTransformOrigin="0.5,0.5">
            <Ellipse.RenderTransform><ScaleTransform x:Name="outerScale"/></Ellipse.RenderTransform>
            <Ellipse.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetName="outerScale" Storyboard.TargetProperty="ScaleX"
                                             From="0.6" To="1.4" Duration="0:0:4" AutoReverse="True" RepeatBehavior="Forever">
                                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation Storyboard.TargetName="outerScale" Storyboard.TargetProperty="ScaleY"
                                             From="0.6" To="1.4" Duration="0:0:4" AutoReverse="True" RepeatBehavior="Forever">
                                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Ellipse.Triggers>
        </Ellipse>
        <Ellipse Width="130" Height="130" HorizontalAlignment="Center" VerticalAlignment="Center"
                 Fill="#2522D3EE" Stroke="#6022D3EE" StrokeThickness="1"
                 RenderTransformOrigin="0.5,0.5">
            <Ellipse.RenderTransform><ScaleTransform x:Name="midScale"/></Ellipse.RenderTransform>
            <Ellipse.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetName="midScale" Storyboard.TargetProperty="ScaleX"
                                             From="0.7" To="1.3" Duration="0:0:4" BeginTime="0:0:0.3" AutoReverse="True" RepeatBehavior="Forever">
                                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation Storyboard.TargetName="midScale" Storyboard.TargetProperty="ScaleY"
                                             From="0.7" To="1.3" Duration="0:0:4" BeginTime="0:0:0.3" AutoReverse="True" RepeatBehavior="Forever">
                                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Ellipse.Triggers>
        </Ellipse>
        <Ellipse Width="60" Height="60" HorizontalAlignment="Center" VerticalAlignment="Center"
                 Fill="#22D3EE" RenderTransformOrigin="0.5,0.5">
            <Ellipse.Effect><DropShadowEffect ShadowDepth="0" BlurRadius="20" Color="#22D3EE" Opacity="0.6"/></Ellipse.Effect>
            <Ellipse.RenderTransform><ScaleTransform x:Name="innerScale"/></Ellipse.RenderTransform>
            <Ellipse.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetName="innerScale" Storyboard.TargetProperty="ScaleX"
                                             From="0.8" To="1.2" Duration="0:0:4" AutoReverse="True" RepeatBehavior="Forever">
                                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation Storyboard.TargetName="innerScale" Storyboard.TargetProperty="ScaleY"
                                             From="0.8" To="1.2" Duration="0:0:4" AutoReverse="True" RepeatBehavior="Forever">
                                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                             From="0.3" To="1.0" Duration="0:0:4" AutoReverse="True" RepeatBehavior="Forever">
                                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Ellipse.Triggers>
        </Ellipse>
    </Grid>
</UserControl>
