<UserControl x:Class="design_wpf_app.Migrated.Sample22_GlitchJitter"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="600"
             Background="#0A0F1C">

    <UserControl.Resources>
        <!-- ═══ GlitchXJitter: rapid X offset ═══ -->
        <Storyboard x:Key="GlitchXJitter" RepeatBehavior="Forever">
            <DoubleAnimationUsingKeyFrames
                Storyboard.TargetName="GlitchTranslate"
                Storyboard.TargetProperty="X">
                <DiscreteDoubleKeyFrame KeyTime="0:0:0.00" Value="0"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:0.05" Value="-8"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:0.10" Value="12"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:0.15" Value="-4"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:0.20" Value="0"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:0.80" Value="0"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:0.85" Value="6"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:0.90" Value="-10"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:0.95" Value="3"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:1.00" Value="0"/>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>

        <!-- ═══ GlitchYJitter: rapid Y offset ═══ -->
        <Storyboard x:Key="GlitchYJitter" RepeatBehavior="Forever">
            <DoubleAnimationUsingKeyFrames
                Storyboard.TargetName="GlitchTranslate"
                Storyboard.TargetProperty="Y">
                <DiscreteDoubleKeyFrame KeyTime="0:0:0.00" Value="0"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:0.05" Value="3"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:0.10" Value="-5"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:0.15" Value="2"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:0.20" Value="0"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:1.00" Value="0"/>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>

        <!-- ═══ GlitchOpacityFlicker ═══ -->
        <Storyboard x:Key="GlitchOpacityFlicker" RepeatBehavior="Forever">
            <DoubleAnimationUsingKeyFrames
                Storyboard.TargetName="GlitchTarget"
                Storyboard.TargetProperty="Opacity">
                <DiscreteDoubleKeyFrame KeyTime="0:0:0.00" Value="1"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:0.07" Value="0.3"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:0.12" Value="1"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:0.17" Value="0.6"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:0.22" Value="1"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:1.00" Value="1"/>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>

        <!-- ═══ GlitchScaleDistortion ═══ -->
        <Storyboard x:Key="GlitchScaleDistortion" RepeatBehavior="Forever">
            <DoubleAnimationUsingKeyFrames
                Storyboard.TargetName="GlitchScale"
                Storyboard.TargetProperty="ScaleX">
                <DiscreteDoubleKeyFrame KeyTime="0:0:0.00" Value="1"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:0.08" Value="1.03"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:0.12" Value="0.97"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:0.20" Value="1"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:1.00" Value="1"/>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>

        <!--
        ═══ DemoSequence ═══
        원본 의도: 글리치/디지털 깨짐 효과 — 순간적인 XY 위치 떨림 + 투명도 깜빡임 + ScaleX 왜곡
        시나리오: 1초 주기로 0~0.2초 구간 격렬한 글리치 → 0.2~0.8초 정지 → 0.8~1초 재글리치 반복
        핵심 기법: DiscreteDoubleKeyFrame (보간 없이 즉시 값 전환), TranslateTransform + ScaleTransform
        다른 플랫폼: CSS — transform: translate() scale(), animation: steps(1) for discrete jumps
        -->
        <Storyboard x:Key="DemoSequence" RepeatBehavior="Forever">
            <!-- X jitter -->
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="GlitchTranslate" Storyboard.TargetProperty="X">
                <DiscreteDoubleKeyFrame KeyTime="0:0:0.00" Value="0"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:0.05" Value="-8"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:0.10" Value="12"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:0.15" Value="-4"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:0.20" Value="0"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:0.80" Value="0"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:0.85" Value="6"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:0.90" Value="-10"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:0.95" Value="3"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:1.00" Value="0"/>
            </DoubleAnimationUsingKeyFrames>
            <!-- Y jitter -->
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="GlitchTranslate" Storyboard.TargetProperty="Y">
                <DiscreteDoubleKeyFrame KeyTime="0:0:0.00" Value="0"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:0.05" Value="3"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:0.10" Value="-5"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:0.15" Value="2"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:0.20" Value="0"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:1.00" Value="0"/>
            </DoubleAnimationUsingKeyFrames>
            <!-- Opacity flicker -->
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="GlitchTarget" Storyboard.TargetProperty="Opacity">
                <DiscreteDoubleKeyFrame KeyTime="0:0:0.00" Value="1"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:0.07" Value="0.3"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:0.12" Value="1"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:0.17" Value="0.6"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:0.22" Value="1"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:1.00" Value="1"/>
            </DoubleAnimationUsingKeyFrames>
            <!-- ScaleX distortion -->
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="GlitchScale" Storyboard.TargetProperty="ScaleX">
                <DiscreteDoubleKeyFrame KeyTime="0:0:0.00" Value="1"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:0.08" Value="1.03"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:0.12" Value="0.97"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:0.20" Value="1"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:1.00" Value="1"/>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>
    </UserControl.Resources>

    <Grid>
        <Border x:Name="GlitchTarget"
                Width="300" Height="80"
                Background="#1E293B"
                BorderBrush="#22D3EE" BorderThickness="1"
                CornerRadius="8"
                RenderTransformOrigin="0.5,0.5">
            <Border.RenderTransform>
                <TransformGroup>
                    <TranslateTransform x:Name="GlitchTranslate" X="0" Y="0"/>
                    <ScaleTransform x:Name="GlitchScale" ScaleX="1" ScaleY="1"/>
                </TransformGroup>
            </Border.RenderTransform>
            <TextBlock Text="SYSTEM ERROR"
                       FontFamily="JetBrains Mono" FontSize="24" FontWeight="Bold"
                       Foreground="#22D3EE"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <Border.Triggers>
                <EventTrigger RoutedEvent="Border.Loaded">
                    <BeginStoryboard>
                        <Storyboard RepeatBehavior="Forever">
                            <!-- Rapid X jitter -->
                            <DoubleAnimationUsingKeyFrames
                                Storyboard.TargetName="GlitchTranslate"
                                Storyboard.TargetProperty="X">
                                <DiscreteDoubleKeyFrame KeyTime="0:0:0.00" Value="0"/>
                                <DiscreteDoubleKeyFrame KeyTime="0:0:0.05" Value="-8"/>
                                <DiscreteDoubleKeyFrame KeyTime="0:0:0.10" Value="12"/>
                                <DiscreteDoubleKeyFrame KeyTime="0:0:0.15" Value="-4"/>
                                <DiscreteDoubleKeyFrame KeyTime="0:0:0.20" Value="0"/>
                                <DiscreteDoubleKeyFrame KeyTime="0:0:0.80" Value="0"/>
                                <DiscreteDoubleKeyFrame KeyTime="0:0:0.85" Value="6"/>
                                <DiscreteDoubleKeyFrame KeyTime="0:0:0.90" Value="-10"/>
                                <DiscreteDoubleKeyFrame KeyTime="0:0:0.95" Value="3"/>
                                <DiscreteDoubleKeyFrame KeyTime="0:0:1.00" Value="0"/>
                            </DoubleAnimationUsingKeyFrames>

                            <!-- Y jitter (smaller amplitude) -->
                            <DoubleAnimationUsingKeyFrames
                                Storyboard.TargetName="GlitchTranslate"
                                Storyboard.TargetProperty="Y">
                                <DiscreteDoubleKeyFrame KeyTime="0:0:0.00" Value="0"/>
                                <DiscreteDoubleKeyFrame KeyTime="0:0:0.05" Value="3"/>
                                <DiscreteDoubleKeyFrame KeyTime="0:0:0.10" Value="-5"/>
                                <DiscreteDoubleKeyFrame KeyTime="0:0:0.15" Value="2"/>
                                <DiscreteDoubleKeyFrame KeyTime="0:0:0.20" Value="0"/>
                                <DiscreteDoubleKeyFrame KeyTime="0:0:1.00" Value="0"/>
                            </DoubleAnimationUsingKeyFrames>

                            <!-- Opacity flicker -->
                            <DoubleAnimationUsingKeyFrames
                                Storyboard.TargetName="GlitchTarget"
                                Storyboard.TargetProperty="Opacity">
                                <DiscreteDoubleKeyFrame KeyTime="0:0:0.00" Value="1"/>
                                <DiscreteDoubleKeyFrame KeyTime="0:0:0.07" Value="0.3"/>
                                <DiscreteDoubleKeyFrame KeyTime="0:0:0.12" Value="1"/>
                                <DiscreteDoubleKeyFrame KeyTime="0:0:0.17" Value="0.6"/>
                                <DiscreteDoubleKeyFrame KeyTime="0:0:0.22" Value="1"/>
                                <DiscreteDoubleKeyFrame KeyTime="0:0:1.00" Value="1"/>
                            </DoubleAnimationUsingKeyFrames>

                            <!-- ScaleX distortion burst -->
                            <DoubleAnimationUsingKeyFrames
                                Storyboard.TargetName="GlitchScale"
                                Storyboard.TargetProperty="ScaleX">
                                <DiscreteDoubleKeyFrame KeyTime="0:0:0.00" Value="1"/>
                                <DiscreteDoubleKeyFrame KeyTime="0:0:0.08" Value="1.03"/>
                                <DiscreteDoubleKeyFrame KeyTime="0:0:0.12" Value="0.97"/>
                                <DiscreteDoubleKeyFrame KeyTime="0:0:0.20" Value="1"/>
                                <DiscreteDoubleKeyFrame KeyTime="0:0:1.00" Value="1"/>
                            </DoubleAnimationUsingKeyFrames>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Border.Triggers>
        </Border>
    </Grid>
</UserControl>
