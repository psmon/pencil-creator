<UserControl x:Class="design_wpf_app.Migrated.Sample17_PulsingGlow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="700"
             Background="#1E1E2E">

    <UserControl.Resources>
        <!-- Glow Button Template -->
        <Style x:Key="GlowButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBorder" Background="{TemplateBinding Background}"
                                CornerRadius="10" Padding="28,14"
                                BorderThickness="1" BorderBrush="#3A3A4E">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="BorderBrush" Value="#5A5A7E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Blue Glow Pulse -->
        <Storyboard x:Key="BlueGlowPulse">
            <DoubleAnimation Storyboard.TargetName="BlueGlow"
                             Storyboard.TargetProperty="BlurRadius"
                             From="10" To="30" Duration="0:0:1.2"
                             AutoReverse="True" RepeatBehavior="Forever">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="BlueGlow"
                             Storyboard.TargetProperty="Opacity"
                             From="0.4" To="0.9" Duration="0:0:1.2"
                             AutoReverse="True" RepeatBehavior="Forever">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Purple Glow Pulse -->
        <Storyboard x:Key="PurpleGlowPulse">
            <DoubleAnimation Storyboard.TargetName="PurpleGlow"
                             Storyboard.TargetProperty="BlurRadius"
                             From="10" To="30" Duration="0:0:1.2"
                             AutoReverse="True" RepeatBehavior="Forever">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="PurpleGlow"
                             Storyboard.TargetProperty="Opacity"
                             From="0.4" To="0.9" Duration="0:0:1.2"
                             AutoReverse="True" RepeatBehavior="Forever">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Green Glow Pulse -->
        <Storyboard x:Key="GreenGlowPulse">
            <DoubleAnimation Storyboard.TargetName="GreenGlow"
                             Storyboard.TargetProperty="BlurRadius"
                             From="10" To="30" Duration="0:0:1.2"
                             AutoReverse="True" RepeatBehavior="Forever">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="GreenGlow"
                             Storyboard.TargetProperty="Opacity"
                             From="0.4" To="0.9" Duration="0:0:1.2"
                             AutoReverse="True" RepeatBehavior="Forever">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Orange Glow Pulse -->
        <Storyboard x:Key="OrangeGlowPulse">
            <DoubleAnimation Storyboard.TargetName="OrangeGlow"
                             Storyboard.TargetProperty="BlurRadius"
                             From="10" To="30" Duration="0:0:1.2"
                             AutoReverse="True" RepeatBehavior="Forever">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="OrangeGlow"
                             Storyboard.TargetProperty="Opacity"
                             From="0.4" To="0.9" Duration="0:0:1.2"
                             AutoReverse="True" RepeatBehavior="Forever">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Pink Glow Pulse -->
        <Storyboard x:Key="PinkGlowPulse">
            <DoubleAnimation Storyboard.TargetName="PinkGlow"
                             Storyboard.TargetProperty="BlurRadius"
                             From="10" To="30" Duration="0:0:1.2"
                             AutoReverse="True" RepeatBehavior="Forever">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="PinkGlow"
                             Storyboard.TargetProperty="Opacity"
                             From="0.4" To="0.9" Duration="0:0:1.2"
                             AutoReverse="True" RepeatBehavior="Forever">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- ★ DemoSequence
             원본 의도: 펄싱 글로우 버튼 — 각 버튼이 서로 다른 색상의 글로우로 맥박처럼 빛남
             시나리오: Blue 글로우 시작(BlurRadius 10→30, Opacity 0.4→0.9) → 0.3s 후 Purple
                       → 0.6s 후 Green → 0.9s 후 Orange → 1.2s 후 Pink, 각각 1사이클 후 HoldEnd
             핵심 기법: DropShadowEffect의 BlurRadius + Opacity 동시 애니메이션,
                        SineEase EaseInOut으로 부드러운 맥박, BeginTime 스태거
             다른 플랫폼:
               - 웹: CSS box-shadow animation + animation-delay, 또는 filter: drop-shadow keyframes
               - 모바일: iOS layer.shadowRadius/shadowOpacity 애니메이션, Android elevation + ViewPropertyAnimator
        -->
        <Storyboard x:Key="DemoSequence">
            <!-- Blue: 1 cycle at 0s -->
            <DoubleAnimation Storyboard.TargetName="BlueGlow"
                             Storyboard.TargetProperty="BlurRadius"
                             From="10" To="30" Duration="0:0:1.2"
                             AutoReverse="True" BeginTime="0:0:0" FillBehavior="HoldEnd">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="BlueGlow"
                             Storyboard.TargetProperty="Opacity"
                             From="0.4" To="0.9" Duration="0:0:1.2"
                             AutoReverse="True" BeginTime="0:0:0" FillBehavior="HoldEnd">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>

            <!-- Purple: 1 cycle at 0.3s -->
            <DoubleAnimation Storyboard.TargetName="PurpleGlow"
                             Storyboard.TargetProperty="BlurRadius"
                             From="10" To="30" Duration="0:0:1.2"
                             AutoReverse="True" BeginTime="0:0:0.3" FillBehavior="HoldEnd">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="PurpleGlow"
                             Storyboard.TargetProperty="Opacity"
                             From="0.4" To="0.9" Duration="0:0:1.2"
                             AutoReverse="True" BeginTime="0:0:0.3" FillBehavior="HoldEnd">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>

            <!-- Green: 1 cycle at 0.6s -->
            <DoubleAnimation Storyboard.TargetName="GreenGlow"
                             Storyboard.TargetProperty="BlurRadius"
                             From="10" To="30" Duration="0:0:1.2"
                             AutoReverse="True" BeginTime="0:0:0.6" FillBehavior="HoldEnd">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="GreenGlow"
                             Storyboard.TargetProperty="Opacity"
                             From="0.4" To="0.9" Duration="0:0:1.2"
                             AutoReverse="True" BeginTime="0:0:0.6" FillBehavior="HoldEnd">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>

            <!-- Orange: 1 cycle at 0.9s -->
            <DoubleAnimation Storyboard.TargetName="OrangeGlow"
                             Storyboard.TargetProperty="BlurRadius"
                             From="10" To="30" Duration="0:0:1.2"
                             AutoReverse="True" BeginTime="0:0:0.9" FillBehavior="HoldEnd">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="OrangeGlow"
                             Storyboard.TargetProperty="Opacity"
                             From="0.4" To="0.9" Duration="0:0:1.2"
                             AutoReverse="True" BeginTime="0:0:0.9" FillBehavior="HoldEnd">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>

            <!-- Pink: 1 cycle at 1.2s -->
            <DoubleAnimation Storyboard.TargetName="PinkGlow"
                             Storyboard.TargetProperty="BlurRadius"
                             From="10" To="30" Duration="0:0:1.2"
                             AutoReverse="True" BeginTime="0:0:1.2" FillBehavior="HoldEnd">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="PinkGlow"
                             Storyboard.TargetProperty="Opacity"
                             From="0.4" To="0.9" Duration="0:0:1.2"
                             AutoReverse="True" BeginTime="0:0:1.2" FillBehavior="HoldEnd">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </UserControl.Resources>

    <!-- Loaded trigger: auto-play all glow pulses forever -->
    <UserControl.Triggers>
        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <!-- Blue Glow -->
                    <DoubleAnimation Storyboard.TargetName="BlueGlow"
                                     Storyboard.TargetProperty="BlurRadius"
                                     From="10" To="30" Duration="0:0:1.2"
                                     AutoReverse="True" RepeatBehavior="Forever">
                        <DoubleAnimation.EasingFunction>
                            <SineEase EasingMode="EaseInOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="BlueGlow"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0.4" To="0.9" Duration="0:0:1.2"
                                     AutoReverse="True" RepeatBehavior="Forever">
                        <DoubleAnimation.EasingFunction>
                            <SineEase EasingMode="EaseInOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>

                    <!-- Purple Glow -->
                    <DoubleAnimation Storyboard.TargetName="PurpleGlow"
                                     Storyboard.TargetProperty="BlurRadius"
                                     From="10" To="30" Duration="0:0:1.2"
                                     AutoReverse="True" RepeatBehavior="Forever"
                                     BeginTime="0:0:0.3">
                        <DoubleAnimation.EasingFunction>
                            <SineEase EasingMode="EaseInOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="PurpleGlow"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0.4" To="0.9" Duration="0:0:1.2"
                                     AutoReverse="True" RepeatBehavior="Forever"
                                     BeginTime="0:0:0.3">
                        <DoubleAnimation.EasingFunction>
                            <SineEase EasingMode="EaseInOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>

                    <!-- Green Glow -->
                    <DoubleAnimation Storyboard.TargetName="GreenGlow"
                                     Storyboard.TargetProperty="BlurRadius"
                                     From="10" To="30" Duration="0:0:1.2"
                                     AutoReverse="True" RepeatBehavior="Forever"
                                     BeginTime="0:0:0.6">
                        <DoubleAnimation.EasingFunction>
                            <SineEase EasingMode="EaseInOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="GreenGlow"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0.4" To="0.9" Duration="0:0:1.2"
                                     AutoReverse="True" RepeatBehavior="Forever"
                                     BeginTime="0:0:0.6">
                        <DoubleAnimation.EasingFunction>
                            <SineEase EasingMode="EaseInOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>

                    <!-- Orange Glow -->
                    <DoubleAnimation Storyboard.TargetName="OrangeGlow"
                                     Storyboard.TargetProperty="BlurRadius"
                                     From="10" To="30" Duration="0:0:1.2"
                                     AutoReverse="True" RepeatBehavior="Forever"
                                     BeginTime="0:0:0.9">
                        <DoubleAnimation.EasingFunction>
                            <SineEase EasingMode="EaseInOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="OrangeGlow"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0.4" To="0.9" Duration="0:0:1.2"
                                     AutoReverse="True" RepeatBehavior="Forever"
                                     BeginTime="0:0:0.9">
                        <DoubleAnimation.EasingFunction>
                            <SineEase EasingMode="EaseInOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>

                    <!-- Pink Glow -->
                    <DoubleAnimation Storyboard.TargetName="PinkGlow"
                                     Storyboard.TargetProperty="BlurRadius"
                                     From="10" To="30" Duration="0:0:1.2"
                                     AutoReverse="True" RepeatBehavior="Forever"
                                     BeginTime="0:0:1.2">
                        <DoubleAnimation.EasingFunction>
                            <SineEase EasingMode="EaseInOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="PinkGlow"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0.4" To="0.9" Duration="0:0:1.2"
                                     AutoReverse="True" RepeatBehavior="Forever"
                                     BeginTime="0:0:1.2">
                        <DoubleAnimation.EasingFunction>
                            <SineEase EasingMode="EaseInOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>

    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="Pulsing Glow Buttons" FontSize="28" FontWeight="Bold"
                       Foreground="#CDD6F4" HorizontalAlignment="Center" Margin="0,0,0,12"/>
            <TextBlock Text="Each button pulses with a different colored glow, staggered in timing"
                       FontSize="13" Foreground="#585B70" HorizontalAlignment="Center" Margin="0,0,0,40"/>

            <!-- Row 1 -->
            <WrapPanel HorizontalAlignment="Center" Margin="0,0,0,20">
                <!-- Blue Glow Button -->
                <Button Content="Primary Action" Background="#2A2A3E"
                        Style="{StaticResource GlowButtonStyle}" Margin="12">
                    <Button.Effect>
                        <DropShadowEffect x:Name="BlueGlow" ShadowDepth="0"
                                          Color="#2196F3" BlurRadius="10" Opacity="0.4"/>
                    </Button.Effect>
                </Button>

                <!-- Purple Glow Button -->
                <Button Content="Secondary" Background="#2A2A3E"
                        Style="{StaticResource GlowButtonStyle}" Margin="12">
                    <Button.Effect>
                        <DropShadowEffect x:Name="PurpleGlow" ShadowDepth="0"
                                          Color="#CE93D8" BlurRadius="10" Opacity="0.4"/>
                    </Button.Effect>
                </Button>

                <!-- Green Glow Button -->
                <Button Content="Success" Background="#2A2A3E"
                        Style="{StaticResource GlowButtonStyle}" Margin="12">
                    <Button.Effect>
                        <DropShadowEffect x:Name="GreenGlow" ShadowDepth="0"
                                          Color="#4CAF50" BlurRadius="10" Opacity="0.4"/>
                    </Button.Effect>
                </Button>
            </WrapPanel>

            <!-- Row 2 -->
            <WrapPanel HorizontalAlignment="Center">
                <!-- Orange Glow Button -->
                <Button Content="Warning" Background="#2A2A3E"
                        Style="{StaticResource GlowButtonStyle}" Margin="12">
                    <Button.Effect>
                        <DropShadowEffect x:Name="OrangeGlow" ShadowDepth="0"
                                          Color="#FF9800" BlurRadius="10" Opacity="0.4"/>
                    </Button.Effect>
                </Button>

                <!-- Pink Glow Button -->
                <Button Content="Danger" Background="#2A2A3E"
                        Style="{StaticResource GlowButtonStyle}" Margin="12">
                    <Button.Effect>
                        <DropShadowEffect x:Name="PinkGlow" ShadowDepth="0"
                                          Color="#F06292" BlurRadius="10" Opacity="0.4"/>
                    </Button.Effect>
                </Button>
            </WrapPanel>
        </StackPanel>
    </Grid>
</UserControl>
