<UserControl x:Class="design_wpf_app.Migrated.Sample13_TabSlide"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="700"
             Background="#1E1E2E">

    <UserControl.Resources>
        <!-- Slide In From Right -->
        <Storyboard x:Key="SlideInRight">
            <DoubleAnimation Storyboard.TargetName="TabContentTransform"
                             Storyboard.TargetProperty="X"
                             From="200" To="0" Duration="0:0:0.35">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="MainTabControl"
                             Storyboard.TargetProperty="Opacity"
                             From="0.3" To="1" Duration="0:0:0.35">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Slide In From Left -->
        <Storyboard x:Key="SlideInLeft">
            <DoubleAnimation Storyboard.TargetName="TabContentTransform"
                             Storyboard.TargetProperty="X"
                             From="-200" To="0" Duration="0:0:0.35">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="MainTabControl"
                             Storyboard.TargetProperty="Opacity"
                             From="0.3" To="1" Duration="0:0:0.35">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Tab Header Style -->
        <Style x:Key="ModernTabItem" TargetType="TabItem">
            <Setter Property="Foreground" Value="#A6ADC8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder" Padding="{TemplateBinding Padding}"
                                Background="Transparent" CornerRadius="8,8,0,0"
                                Margin="2,0" Cursor="Hand">
                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#2A2A3E"/>
                                <Setter Property="Foreground" Value="#CDD6F4"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#252538"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ★ DemoSequence
             원본 의도: 탭 전환 시 슬라이드 애니메이션 — 좌/우 방향에 따라 콘텐츠가 슬라이드하며 페이드
             시나리오: Dashboard 탭이 표시된 상태에서 1초 대기
                       → 오른쪽에서 슬라이드 인(1~1.35s, Settings 탭 전환 시뮬레이션)
                       → 1.5초 대기 후 왼쪽에서 슬라이드 인(2.85~3.2s, Dashboard 복귀 시뮬레이션)
             핵심 기법: TranslateTransform.X 방향별 슬라이드, Opacity 페이드,
                        QuadraticEase EaseOut으로 자연스러운 감속
             다른 플랫폼:
               - 웹: CSS transform translateX + opacity transition, 또는 Swiper/탭 라이브러리
               - 모바일: TabLayout + ViewPager2(Android), UITabBarController 커스텀 전환(iOS)
        -->
        <Storyboard x:Key="DemoSequence">
            <!-- Phase 1: Slide in from right (1~1.35s) — simulates tab switch to Settings -->
            <DoubleAnimation Storyboard.TargetName="TabContentTransform"
                             Storyboard.TargetProperty="X"
                             From="200" To="0" Duration="0:0:0.35"
                             BeginTime="0:0:1" FillBehavior="HoldEnd">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="MainTabControl"
                             Storyboard.TargetProperty="Opacity"
                             From="0.3" To="1" Duration="0:0:0.35"
                             BeginTime="0:0:1" FillBehavior="HoldEnd">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>

            <!-- Phase 2: Slide in from left (2.85~3.2s) — simulates tab switch back -->
            <DoubleAnimation Storyboard.TargetName="TabContentTransform"
                             Storyboard.TargetProperty="X"
                             From="-200" To="0" Duration="0:0:0.35"
                             BeginTime="0:0:2.85" FillBehavior="HoldEnd">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="MainTabControl"
                             Storyboard.TargetProperty="Opacity"
                             From="0.3" To="1" Duration="0:0:0.35"
                             BeginTime="0:0:2.85" FillBehavior="HoldEnd">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </UserControl.Resources>

    <Grid Margin="20">
        <TabControl x:Name="MainTabControl" Background="Transparent" BorderThickness="0"
                    ClipToBounds="True">
            <TabControl.RenderTransform>
                <TranslateTransform x:Name="TabContentTransform" X="0" Y="0"/>
            </TabControl.RenderTransform>

            <!-- Tab 1: Dashboard -->
            <TabItem Header="Dashboard" Style="{StaticResource ModernTabItem}">
                <TabItem.Triggers>
                    <EventTrigger RoutedEvent="TabItem.GotFocus">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="TabContentTransform"
                                                 Storyboard.TargetProperty="X"
                                                 From="-200" To="0" Duration="0:0:0.35">
                                    <DoubleAnimation.EasingFunction>
                                        <QuadraticEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetName="MainTabControl"
                                                 Storyboard.TargetProperty="Opacity"
                                                 From="0.3" To="1" Duration="0:0:0.35">
                                    <DoubleAnimation.EasingFunction>
                                        <QuadraticEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </TabItem.Triggers>
                <Border Background="#2A2A3E" CornerRadius="0,12,12,12" Padding="30" Margin="0,0,0,0">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets" FontSize="48"
                                   Foreground="#667eea" HorizontalAlignment="Center"/>
                        <TextBlock Text="Dashboard" FontSize="28" FontWeight="Bold"
                                   Foreground="#CDD6F4" HorizontalAlignment="Center" Margin="0,16,0,0"/>
                        <TextBlock Text="Overview of your activity and statistics"
                                   FontSize="14" Foreground="#A6ADC8" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        <WrapPanel HorizontalAlignment="Center" Margin="0,24,0,0">
                            <Border Background="#313244" CornerRadius="8" Padding="20,14" Margin="6">
                                <StackPanel>
                                    <TextBlock Text="1,234" FontSize="22" FontWeight="Bold" Foreground="#667eea"/>
                                    <TextBlock Text="Visitors" FontSize="12" Foreground="#A6ADC8"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#313244" CornerRadius="8" Padding="20,14" Margin="6">
                                <StackPanel>
                                    <TextBlock Text="567" FontSize="22" FontWeight="Bold" Foreground="#81C784"/>
                                    <TextBlock Text="Sales" FontSize="12" Foreground="#A6ADC8"/>
                                </StackPanel>
                            </Border>
                        </WrapPanel>
                    </StackPanel>
                </Border>
            </TabItem>

            <!-- Tab 2: Settings -->
            <TabItem Header="Settings" Style="{StaticResource ModernTabItem}">
                <TabItem.Triggers>
                    <EventTrigger RoutedEvent="TabItem.GotFocus">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="TabContentTransform"
                                                 Storyboard.TargetProperty="X"
                                                 From="200" To="0" Duration="0:0:0.35">
                                    <DoubleAnimation.EasingFunction>
                                        <QuadraticEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetName="MainTabControl"
                                                 Storyboard.TargetProperty="Opacity"
                                                 From="0.3" To="1" Duration="0:0:0.35">
                                    <DoubleAnimation.EasingFunction>
                                        <QuadraticEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </TabItem.Triggers>
                <Border Background="#2A2A3E" CornerRadius="0,12,12,12" Padding="30">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="48"
                                   Foreground="#CE93D8" HorizontalAlignment="Center"/>
                        <TextBlock Text="Settings" FontSize="28" FontWeight="Bold"
                                   Foreground="#CDD6F4" HorizontalAlignment="Center" Margin="0,16,0,0"/>
                        <TextBlock Text="Configure your application preferences"
                                   FontSize="14" Foreground="#A6ADC8" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        <StackPanel Margin="0,24,0,0" Width="280">
                            <Border Background="#313244" CornerRadius="8" Padding="16,12" Margin="0,4">
                                <TextBlock Text="General Settings" Foreground="#CDD6F4" FontSize="14"/>
                            </Border>
                            <Border Background="#313244" CornerRadius="8" Padding="16,12" Margin="0,4">
                                <TextBlock Text="Notifications" Foreground="#CDD6F4" FontSize="14"/>
                            </Border>
                            <Border Background="#313244" CornerRadius="8" Padding="16,12" Margin="0,4">
                                <TextBlock Text="Privacy" Foreground="#CDD6F4" FontSize="14"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </TabItem>

            <!-- Tab 3: Profile -->
            <TabItem Header="Profile" Style="{StaticResource ModernTabItem}">
                <TabItem.Triggers>
                    <EventTrigger RoutedEvent="TabItem.GotFocus">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="TabContentTransform"
                                                 Storyboard.TargetProperty="X"
                                                 From="200" To="0" Duration="0:0:0.35">
                                    <DoubleAnimation.EasingFunction>
                                        <QuadraticEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetName="MainTabControl"
                                                 Storyboard.TargetProperty="Opacity"
                                                 From="0.3" To="1" Duration="0:0:0.35">
                                    <DoubleAnimation.EasingFunction>
                                        <QuadraticEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </TabItem.Triggers>
                <Border Background="#2A2A3E" CornerRadius="0,12,12,12" Padding="30">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Ellipse Width="80" Height="80" HorizontalAlignment="Center">
                            <Ellipse.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#f093fb" Offset="0"/>
                                    <GradientStop Color="#f5576c" Offset="1"/>
                                </LinearGradientBrush>
                            </Ellipse.Fill>
                        </Ellipse>
                        <TextBlock Text="Profile" FontSize="28" FontWeight="Bold"
                                   Foreground="#CDD6F4" HorizontalAlignment="Center" Margin="0,16,0,0"/>
                        <TextBlock Text="Manage your account and personal information"
                                   FontSize="14" Foreground="#A6ADC8" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        <Border Background="#313244" CornerRadius="8" Padding="20" Margin="0,24,0,0" Width="280">
                            <StackPanel>
                                <TextBlock Text="Name: John Doe" Foreground="#CDD6F4" FontSize="14" Margin="0,4"/>
                                <TextBlock Text="Email: john@example.com" Foreground="#A6ADC8" FontSize="13" Margin="0,4"/>
                                <TextBlock Text="Role: Administrator" Foreground="#A6ADC8" FontSize="13" Margin="0,4"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
