<UserControl x:Class="design_wpf_app.Migrated.Sample14_HamburgerToX"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="700"
             Background="#1E1E2E">

    <UserControl.Resources>
        <!-- To X Animation -->
        <Storyboard x:Key="ToX">
            <!-- Middle line fade out -->
            <DoubleAnimation Storyboard.TargetName="MiddleLine"
                             Storyboard.TargetProperty="Opacity"
                             To="0" Duration="0:0:0.25">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>

            <!-- Top line rotate 45 -->
            <DoubleAnimation Storyboard.TargetName="TopLineRotate"
                             Storyboard.TargetProperty="Angle"
                             To="45" Duration="0:0:0.25">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <!-- Top line translate Y+7 -->
            <DoubleAnimation Storyboard.TargetName="TopLineTranslate"
                             Storyboard.TargetProperty="Y"
                             To="7" Duration="0:0:0.25">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>

            <!-- Bottom line rotate -45 -->
            <DoubleAnimation Storyboard.TargetName="BottomLineRotate"
                             Storyboard.TargetProperty="Angle"
                             To="-45" Duration="0:0:0.25">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <!-- Bottom line translate Y-7 -->
            <DoubleAnimation Storyboard.TargetName="BottomLineTranslate"
                             Storyboard.TargetProperty="Y"
                             To="-7" Duration="0:0:0.25">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Back to Hamburger Animation -->
        <Storyboard x:Key="ToHamburger">
            <!-- Middle line fade in -->
            <DoubleAnimation Storyboard.TargetName="MiddleLine"
                             Storyboard.TargetProperty="Opacity"
                             To="1" Duration="0:0:0.25">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>

            <!-- Top line rotate back -->
            <DoubleAnimation Storyboard.TargetName="TopLineRotate"
                             Storyboard.TargetProperty="Angle"
                             To="0" Duration="0:0:0.25">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="TopLineTranslate"
                             Storyboard.TargetProperty="Y"
                             To="0" Duration="0:0:0.25">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>

            <!-- Bottom line rotate back -->
            <DoubleAnimation Storyboard.TargetName="BottomLineRotate"
                             Storyboard.TargetProperty="Angle"
                             To="0" Duration="0:0:0.25">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="BottomLineTranslate"
                             Storyboard.TargetProperty="Y"
                             To="0" Duration="0:0:0.25">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- ★ DemoSequence
             원본 의도: 햄버거 메뉴 아이콘이 X 아이콘으로 모핑 — 3개 라인이 회전/이동/페이드
             시나리오: 햄버거(3줄) 상태로 1초 대기
                       → 중간 줄 페이드아웃 + 상단 줄 45도 회전/Y+7 이동 + 하단 줄 -45도 회전/Y-7 이동(1~1.25s)
                       → X 상태 1.5초 유지
                       → 원래 햄버거 상태로 복귀(2.75~3.0s)
             핵심 기법: RotateTransform.Angle 회전, TranslateTransform.Y 이동,
                        Opacity 페이드, CubicEase EaseInOut으로 부드러운 전환
             다른 플랫폼:
               - 웹: CSS transform rotate + translateY, opacity transition (흔한 햄버거 토글 패턴)
               - 모바일: CABasicAnimation(iOS), ObjectAnimator(Android), 또는 Lottie 사용
        -->
        <Storyboard x:Key="DemoSequence">
            <!-- Phase 1: To X (1~1.25s) -->
            <DoubleAnimation Storyboard.TargetName="MiddleLine"
                             Storyboard.TargetProperty="Opacity"
                             From="1" To="0" Duration="0:0:0.25"
                             BeginTime="0:0:1" FillBehavior="HoldEnd">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="TopLineRotate"
                             Storyboard.TargetProperty="Angle"
                             From="0" To="45" Duration="0:0:0.25"
                             BeginTime="0:0:1" FillBehavior="HoldEnd">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="TopLineTranslate"
                             Storyboard.TargetProperty="Y"
                             From="0" To="7" Duration="0:0:0.25"
                             BeginTime="0:0:1" FillBehavior="HoldEnd">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="BottomLineRotate"
                             Storyboard.TargetProperty="Angle"
                             From="0" To="-45" Duration="0:0:0.25"
                             BeginTime="0:0:1" FillBehavior="HoldEnd">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="BottomLineTranslate"
                             Storyboard.TargetProperty="Y"
                             From="0" To="-7" Duration="0:0:0.25"
                             BeginTime="0:0:1" FillBehavior="HoldEnd">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>

            <!-- Phase 2: Back to Hamburger (2.75~3.0s) -->
            <DoubleAnimation Storyboard.TargetName="MiddleLine"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.25"
                             BeginTime="0:0:2.75" FillBehavior="HoldEnd">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="TopLineRotate"
                             Storyboard.TargetProperty="Angle"
                             From="45" To="0" Duration="0:0:0.25"
                             BeginTime="0:0:2.75" FillBehavior="HoldEnd">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="TopLineTranslate"
                             Storyboard.TargetProperty="Y"
                             From="7" To="0" Duration="0:0:0.25"
                             BeginTime="0:0:2.75" FillBehavior="HoldEnd">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="BottomLineRotate"
                             Storyboard.TargetProperty="Angle"
                             From="-45" To="0" Duration="0:0:0.25"
                             BeginTime="0:0:2.75" FillBehavior="HoldEnd">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="BottomLineTranslate"
                             Storyboard.TargetProperty="Y"
                             From="-7" To="0" Duration="0:0:0.25"
                             BeginTime="0:0:2.75" FillBehavior="HoldEnd">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </UserControl.Resources>

    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="Hamburger to X" FontSize="28" FontWeight="Bold"
                       Foreground="#CDD6F4" HorizontalAlignment="Center" Margin="0,0,0,40"/>

            <!-- Extracted hamburger lines at root level for Storyboard targeting -->
            <Border Background="#2A2A3E" CornerRadius="12"
                    Width="56" Height="56" HorizontalAlignment="Center">
                <Canvas Width="24" Height="18" HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <!-- Top Line -->
                    <Rectangle x:Name="TopLine" Width="24" Height="2.5"
                               Fill="#CDD6F4" RadiusX="1.25" RadiusY="1.25"
                               Canvas.Top="0" RenderTransformOrigin="0.5,0.5">
                        <Rectangle.RenderTransform>
                            <TransformGroup>
                                <RotateTransform x:Name="TopLineRotate" Angle="0"/>
                                <TranslateTransform x:Name="TopLineTranslate" Y="0"/>
                            </TransformGroup>
                        </Rectangle.RenderTransform>
                    </Rectangle>

                    <!-- Middle Line -->
                    <Rectangle x:Name="MiddleLine" Width="24" Height="2.5"
                               Fill="#CDD6F4" RadiusX="1.25" RadiusY="1.25"
                               Canvas.Top="7.5" Opacity="1"/>

                    <!-- Bottom Line -->
                    <Rectangle x:Name="BottomLine" Width="24" Height="2.5"
                               Fill="#CDD6F4" RadiusX="1.25" RadiusY="1.25"
                               Canvas.Top="15" RenderTransformOrigin="0.5,0.5">
                        <Rectangle.RenderTransform>
                            <TransformGroup>
                                <RotateTransform x:Name="BottomLineRotate" Angle="0"/>
                                <TranslateTransform x:Name="BottomLineTranslate" Y="0"/>
                            </TransformGroup>
                        </Rectangle.RenderTransform>
                    </Rectangle>
                </Canvas>
            </Border>

            <!-- Toggle button for interactive control -->
            <ToggleButton x:Name="HamburgerToggle" Content="Toggle"
                          HorizontalAlignment="Center" Margin="0,20,0,0"
                          Padding="16,8" FontSize="13" Foreground="White"
                          Cursor="Hand" BorderThickness="0">
                <ToggleButton.Style>
                    <Style TargetType="ToggleButton">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border x:Name="ToggleBtnBg" Background="#313244" CornerRadius="8"
                                            Padding="16,8" Cursor="Hand">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="ToggleBtnBg" Property="Background" Value="#3A3A50"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard Storyboard="{StaticResource ToX}"/>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard Storyboard="{StaticResource ToHamburger}"/>
                                </Trigger.ExitActions>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ToggleButton.Style>
            </ToggleButton>

            <TextBlock Text="Click the toggle to switch" FontSize="13" Foreground="#585B70"
                       HorizontalAlignment="Center" Margin="0,12,0,0"/>

            <!-- Larger demo version -->
            <TextBlock Text="Large Preview" FontSize="16" FontWeight="SemiBold"
                       Foreground="#A6ADC8" HorizontalAlignment="Center" Margin="0,50,0,16"/>

            <Border Background="#2A2A3E" CornerRadius="16" Width="120" Height="120"
                    HorizontalAlignment="Center">
                <Canvas Width="50" Height="38" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Rectangle Width="50" Height="5" Fill="#667eea" RadiusX="2.5" RadiusY="2.5" Canvas.Top="0"/>
                    <Rectangle Width="50" Height="5" Fill="#CE93D8" RadiusX="2.5" RadiusY="2.5" Canvas.Top="16"/>
                    <Rectangle Width="50" Height="5" Fill="#f093fb" RadiusX="2.5" RadiusY="2.5" Canvas.Top="32"/>
                </Canvas>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
