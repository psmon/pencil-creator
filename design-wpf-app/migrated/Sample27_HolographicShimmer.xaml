<UserControl x:Class="design_wpf_app.Migrated.Sample27_HolographicShimmer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="600"
             Background="#0A0F1C">

    <UserControl.Resources>
        <!-- Border color cycling -->
        <Storyboard x:Key="HoloBorderColorCycle">
            <ColorAnimation
                Storyboard.TargetName="HoloStop1"
                Storyboard.TargetProperty="Color"
                From="#22D3EE" To="#A855F7"
                Duration="0:0:2">
                <ColorAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </ColorAnimation.EasingFunction>
            </ColorAnimation>
            <ColorAnimation
                Storyboard.TargetName="HoloStop2"
                Storyboard.TargetProperty="Color"
                From="#E040FB" To="#22D3EE"
                Duration="0:0:2">
                <ColorAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </ColorAnimation.EasingFunction>
            </ColorAnimation>
            <ColorAnimation
                Storyboard.TargetName="HoloStop3"
                Storyboard.TargetProperty="Color"
                From="#22D3EE" To="#10B981"
                Duration="0:0:2">
                <ColorAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </ColorAnimation.EasingFunction>
            </ColorAnimation>
            <ColorAnimation
                Storyboard.TargetName="HoloStop4"
                Storyboard.TargetProperty="Color"
                From="#E040FB" To="#F59E0B"
                Duration="0:0:2">
                <ColorAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </ColorAnimation.EasingFunction>
            </ColorAnimation>
        </Storyboard>

        <!-- Shimmer offset sweep -->
        <Storyboard x:Key="HoloOffsetSweep">
            <DoubleAnimation
                Storyboard.TargetName="HoloStop2"
                Storyboard.TargetProperty="Offset"
                From="0.2" To="0.8"
                Duration="0:0:3">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Background color sync -->
        <Storyboard x:Key="HoloBgColorSync">
            <ColorAnimation
                Storyboard.TargetName="BgStop1"
                Storyboard.TargetProperty="Color"
                From="#1A22D3EE" To="#1AA855F7"
                Duration="0:0:2"/>
            <ColorAnimation
                Storyboard.TargetName="BgStop2"
                Storyboard.TargetProperty="Color"
                From="#1AE040FB" To="#1A22D3EE"
                Duration="0:0:2"/>
        </Storyboard>

        <!-- ★ DemoSequence
             원본 의도: 홀로그래픽 쉬머 효과 — 무지개빛 색상 순환과 그라데이션 오프셋 이동
             시나리오: 보더 GradientStop 4개가 Cyan↔Purple↔Green↔Orange로 2초간 색상 전환,
                       HoloStop2 Offset이 0.2→0.8로 3초간 이동하여 쉬머 스윕,
                       배경 GradientStop도 동기화 색상 전환, 1사이클 후 정지
             핵심 기법: ColorAnimation + SineEase로 부드러운 색상 전환,
                        GradientStop Offset 애니메이션으로 빛 이동 효과
             다른 플랫폼:
               - 웹: CSS @property + linear-gradient + hue-rotate 또는 JS로 gradient offset 조작
               - 모바일: CAGradientLayer + CABasicAnimation(colors, locations)
        -->
        <Storyboard x:Key="DemoSequence" FillBehavior="HoldEnd">
            <!-- Color cycling: Cyan to Purple/Green/Orange -->
            <ColorAnimation
                Storyboard.TargetName="HoloStop1"
                Storyboard.TargetProperty="Color"
                From="#22D3EE" To="#A855F7"
                Duration="0:0:2"
                BeginTime="0:0:0">
                <ColorAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </ColorAnimation.EasingFunction>
            </ColorAnimation>
            <ColorAnimation
                Storyboard.TargetName="HoloStop2"
                Storyboard.TargetProperty="Color"
                From="#E040FB" To="#22D3EE"
                Duration="0:0:2"
                BeginTime="0:0:0">
                <ColorAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </ColorAnimation.EasingFunction>
            </ColorAnimation>
            <ColorAnimation
                Storyboard.TargetName="HoloStop3"
                Storyboard.TargetProperty="Color"
                From="#22D3EE" To="#10B981"
                Duration="0:0:2"
                BeginTime="0:0:0">
                <ColorAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </ColorAnimation.EasingFunction>
            </ColorAnimation>
            <ColorAnimation
                Storyboard.TargetName="HoloStop4"
                Storyboard.TargetProperty="Color"
                From="#E040FB" To="#F59E0B"
                Duration="0:0:2"
                BeginTime="0:0:0">
                <ColorAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </ColorAnimation.EasingFunction>
            </ColorAnimation>

            <!-- Offset animation for shimmer sweep -->
            <DoubleAnimation
                Storyboard.TargetName="HoloStop2"
                Storyboard.TargetProperty="Offset"
                From="0.2" To="0.8"
                Duration="0:0:3"
                BeginTime="0:0:0">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>

            <!-- Background color sync -->
            <ColorAnimation
                Storyboard.TargetName="BgStop1"
                Storyboard.TargetProperty="Color"
                From="#1A22D3EE" To="#1AA855F7"
                Duration="0:0:2"
                BeginTime="0:0:0"/>
            <ColorAnimation
                Storyboard.TargetName="BgStop2"
                Storyboard.TargetProperty="Color"
                From="#1AE040FB" To="#1A22D3EE"
                Duration="0:0:2"
                BeginTime="0:0:0"/>
        </Storyboard>
    </UserControl.Resources>

    <!-- Holographic Shimmer: LinearGradientBrush offset animation + iridescent ColorAnimation -->
    <Grid>
        <Border Width="360" Height="200"
                CornerRadius="16"
                BorderThickness="2">
            <Border.BorderBrush>
                <LinearGradientBrush x:Name="HoloBrush"
                                     StartPoint="0,0" EndPoint="1,1">
                    <GradientStop x:Name="HoloStop1" Color="#22D3EE" Offset="0"/>
                    <GradientStop x:Name="HoloStop2" Color="#E040FB" Offset="0.33"/>
                    <GradientStop x:Name="HoloStop3" Color="#22D3EE" Offset="0.66"/>
                    <GradientStop x:Name="HoloStop4" Color="#E040FB" Offset="1"/>
                </LinearGradientBrush>
            </Border.BorderBrush>
            <Border.Background>
                <LinearGradientBrush x:Name="HoloBg"
                                     StartPoint="0,0" EndPoint="1,1">
                    <GradientStop x:Name="BgStop1" Color="#1A22D3EE" Offset="0"/>
                    <GradientStop x:Name="BgStop2" Color="#1AE040FB" Offset="0.5"/>
                    <GradientStop x:Name="BgStop3" Color="#1A22D3EE" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="HOLOGRAPHIC"
                           FontFamily="JetBrains Mono" FontSize="28" FontWeight="Bold"
                           Foreground="#FFFFFF" HorizontalAlignment="Center"/>
                <TextBlock Text="iridescent shimmer effect"
                           FontFamily="Inter" FontSize="14"
                           Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,8,0,0"/>
            </StackPanel>
            <Border.Triggers>
                <EventTrigger RoutedEvent="Border.Loaded">
                    <BeginStoryboard>
                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                            <!-- Color cycling: Cyan to Purple/Green/Orange -->
                            <ColorAnimation
                                Storyboard.TargetName="HoloStop1"
                                Storyboard.TargetProperty="Color"
                                From="#22D3EE" To="#A855F7"
                                Duration="0:0:2">
                                <ColorAnimation.EasingFunction>
                                    <SineEase EasingMode="EaseInOut"/>
                                </ColorAnimation.EasingFunction>
                            </ColorAnimation>
                            <ColorAnimation
                                Storyboard.TargetName="HoloStop2"
                                Storyboard.TargetProperty="Color"
                                From="#E040FB" To="#22D3EE"
                                Duration="0:0:2">
                                <ColorAnimation.EasingFunction>
                                    <SineEase EasingMode="EaseInOut"/>
                                </ColorAnimation.EasingFunction>
                            </ColorAnimation>
                            <ColorAnimation
                                Storyboard.TargetName="HoloStop3"
                                Storyboard.TargetProperty="Color"
                                From="#22D3EE" To="#10B981"
                                Duration="0:0:2">
                                <ColorAnimation.EasingFunction>
                                    <SineEase EasingMode="EaseInOut"/>
                                </ColorAnimation.EasingFunction>
                            </ColorAnimation>
                            <ColorAnimation
                                Storyboard.TargetName="HoloStop4"
                                Storyboard.TargetProperty="Color"
                                From="#E040FB" To="#F59E0B"
                                Duration="0:0:2">
                                <ColorAnimation.EasingFunction>
                                    <SineEase EasingMode="EaseInOut"/>
                                </ColorAnimation.EasingFunction>
                            </ColorAnimation>

                            <!-- Offset animation for shimmer sweep -->
                            <DoubleAnimation
                                Storyboard.TargetName="HoloStop2"
                                Storyboard.TargetProperty="Offset"
                                From="0.2" To="0.8"
                                Duration="0:0:3">
                                <DoubleAnimation.EasingFunction>
                                    <SineEase EasingMode="EaseInOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>

                            <!-- Background color sync -->
                            <ColorAnimation
                                Storyboard.TargetName="BgStop1"
                                Storyboard.TargetProperty="Color"
                                From="#1A22D3EE" To="#1AA855F7"
                                Duration="0:0:2"/>
                            <ColorAnimation
                                Storyboard.TargetName="BgStop2"
                                Storyboard.TargetProperty="Color"
                                From="#1AE040FB" To="#1A22D3EE"
                                Duration="0:0:2"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Border.Triggers>
        </Border>
    </Grid>
</UserControl>
