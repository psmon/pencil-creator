<UserControl x:Class="design_wpf_app.Migrated.Sample31_SoftAuroraGradient"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="600">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop x:Name="stop1" Color="#1E3A5F" Offset="0.0"/>
                <GradientStop x:Name="stop2" Color="#2DD4BF" Offset="0.33"/>
                <GradientStop x:Name="stop3" Color="#7DD3A0" Offset="0.66"/>
                <GradientStop x:Name="stop4" Color="#A78BFA" Offset="1.0"/>
            </LinearGradientBrush>
        </Grid.Background>
        <Grid.Triggers>
            <EventTrigger RoutedEvent="Loaded">
                <BeginStoryboard>
                    <Storyboard>
                        <ColorAnimation Storyboard.TargetName="stop1" Storyboard.TargetProperty="Color" From="#1E3A5F" To="#2DD4BF" Duration="0:0:8" AutoReverse="True" RepeatBehavior="Forever">
                            <ColorAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></ColorAnimation.EasingFunction>
                        </ColorAnimation>
                        <ColorAnimation Storyboard.TargetName="stop2" Storyboard.TargetProperty="Color" From="#2DD4BF" To="#7DD3A0" Duration="0:0:8" AutoReverse="True" RepeatBehavior="Forever">
                            <ColorAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></ColorAnimation.EasingFunction>
                        </ColorAnimation>
                        <ColorAnimation Storyboard.TargetName="stop3" Storyboard.TargetProperty="Color" From="#7DD3A0" To="#A78BFA" Duration="0:0:8" AutoReverse="True" RepeatBehavior="Forever">
                            <ColorAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></ColorAnimation.EasingFunction>
                        </ColorAnimation>
                        <ColorAnimation Storyboard.TargetName="stop4" Storyboard.TargetProperty="Color" From="#A78BFA" To="#1E3A5F" Duration="0:0:8" AutoReverse="True" RepeatBehavior="Forever">
                            <ColorAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></ColorAnimation.EasingFunction>
                        </ColorAnimation>
                        <DoubleAnimation Storyboard.TargetName="stop2" Storyboard.TargetProperty="Offset" From="0.2" To="0.5" Duration="0:0:6" AutoReverse="True" RepeatBehavior="Forever">
                            <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                        <DoubleAnimation Storyboard.TargetName="stop3" Storyboard.TargetProperty="Offset" From="0.5" To="0.8" Duration="0:0:6" AutoReverse="True" RepeatBehavior="Forever">
                            <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Grid.Triggers>
    </Grid>
</UserControl>
