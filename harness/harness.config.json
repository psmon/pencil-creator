{
  "name": "pencil-design-harness",
  "version": "2.5.0",
  "description": "Pencil Design 품질 하네스 — Case A(WPF→템플릿), Case B(템플릿참고→프로젝트 디자인), Case C(웹→JSON→펜슬 컴포넌트), Case W(Pencil→HTML) 평가",
  "scope": "pencil-design",
  "layers": {
    "knowledge": "harness/knowledge/",
    "agents": "harness/agents/",
    "engine": "harness/engine/"
  },
  "evaluation": {
    "design": {
      "cases": {
        "A": { "axes": 3, "maxScore": 100, "label": "WPF → Template Enrichment", "target": "design/wpf-animation.pen" },
        "B": { "axes": 3, "maxScore": 100, "label": "Template Ref → Project Design", "target": "projects/design/*.pen" },
        "C": { "axes": 3, "maxScore": 100, "label": "Web Animation → JSON → Pencil Component (Copycat)", "target": "design/json/sample/*.json" },
        "W": { "axes": 3, "maxScore": 100, "label": "Pencil → HTML (SVG Realism + WAAPI)" }
      },
      "pipeline_bonus": {
        "A_B": { "multiplier": 1.2, "condition": "both >= 60" },
        "A_W": { "multiplier": 1.2, "condition": "both >= 60" },
        "B_W": { "multiplier": 1.3, "condition": "both >= 60" },
        "C_W": { "multiplier": 1.3, "condition": "both >= 60" },
        "C_B": { "multiplier": 1.2, "condition": "both >= 60" },
        "A_B_W": { "multiplier": 1.5, "condition": "all >= 60" },
        "C_B_W": { "multiplier": 1.5, "condition": "all >= 60" }
      },
      "reference": "harness/knowledge/design-craft.md"
    },
    "grades": {
      "A": [80, 100],
      "B": [60, 79],
      "C": [40, 59],
      "D": [0, 39]
    }
  },
  "rpg_system": {
    "enabled": true,
    "max_level": 100,
    "level_state": "harness/logs/level-up/status.json",
    "level_history": "harness/logs/level-up/history.md",
    "achievement_state": "harness/logs/achievements/achievements.json",
    "achievement_history": "harness/logs/achievements/history.md",
    "rules": "harness/engine/level-achievement-system.md",
    "xp_formula": {
      "base": "score * 10",
      "grade_multiplier": { "A": 5, "B": 3, "C": 1, "D": 0.5 },
      "type_multiplier": { "A": 1.2, "B": 1.2, "C": 1.2, "W": 1.2 }
    }
  },
  "skills": {
    "pencil-design": {
      "path": ".claude/skills/pencil-design/",
      "current_version": "1.4.0"
    },
    "harness-creator": {
      "path": ".claude/skills/harness-creator/",
      "current_version": "1.0.0"
    },
    "harness-usage": {
      "path": ".claude/skills/harness-usage/",
      "current_version": "2.4.0"
    }
  }
}
